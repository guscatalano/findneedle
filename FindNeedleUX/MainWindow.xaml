<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FindNeedleUX.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local1="using:FindNeedleUX.ViewObjects"
    mc:Ignorable="d"
    Title="Find Needle">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem Title="Quick">
                <MenuFlyoutItem Text="Open Log File" Click="MenuFlyoutItem_Click" Name="openlogfile" />
                <MenuFlyoutItem Text="Open Folder with logs" Click="MenuFlyoutItem_Click" Name="openlogfolder"/>
                <MenuFlyoutItem Text="Open Log with Rules..." Click="MenuFlyoutItem_Click" Name="openlogwithrules"/>
            </MenuBarItem>
            <MenuBarItem Title="Workspace">
                <MenuFlyoutItem Text="New" Click="MenuFlyoutItem_Click" Name="NewWorkspace" />
                <MenuFlyoutItem Text="Open..." Click="MenuFlyoutItem_Click" Name="OpenWorkspace"/>
                <MenuFlyoutItem Text="Save" Click="MenuFlyoutItem_Click" Name="SaveWorkspace"/>
            </MenuBarItem>
            <MenuBarItem Title="Configure">
                <MenuFlyoutItem Text="Locations" Click="MenuFlyoutItem_Click" Name="search_location"/>
                <MenuFlyoutItem Text="Rules" Click="MenuFlyoutItem_Click" Name="search_rules"/>
                <MenuFlyoutItem Text="Processors" Click="MenuFlyoutItem_Click" Name="search_processors"/>
                <MenuFlyoutItem Text="UML" Click="MenuFlyoutItem_Click" Name="rules_uml"/>
            </MenuBarItem>
            <MenuBarItem Title="Run">
                <MenuFlyoutItem Text="Run Search" Click="MenuFlyoutItem_Click" Name="results_get"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Statistics" Click="MenuFlyoutItem_Click" Name="results_statistics"/>
                <MenuFlyoutItem Text="Performance Report (why so slow?)" Click="MenuFlyoutItem_Click" Name="results_perfreport"/>
            </MenuBarItem>
            <MenuBarItem Title="View Results">
                <MenuFlyoutItem Text="Results" Click="MenuFlyoutItem_Click" Name="results_viewnative"/>
                <MenuFlyoutItem Text="Processor Output" Click="MenuFlyoutItem_Click" Name="results_processoroutput"/>
            </MenuBarItem>

            <MenuBarItem Title="Inspect">
                <MenuFlyoutItem Text="Inspect ETL" Click="MenuFlyoutItem_Click" Name="inspect_etl"/>
                <MenuFlyoutItem Text="Inspect Binary" Click="MenuFlyoutItem_Click" Name="inspect_binary"/>
            </MenuBarItem>

            <MenuBarItem Title="Settings">
                <MenuFlyoutItem Text="Result Viewer..." Click="MenuFlyoutItem_Click" Name="settings_resultviewer"/>
                <MenuFlyoutItem Text="System Check" Click="MenuFlyoutItem_Click" Name="systeminfo"/>
                <MenuFlyoutItem Text="Diagram Tools" Click="MenuFlyoutItem_Click" Name="diagramtools"/>
                <MenuFlyoutItem Text="Plugins" Click="MenuFlyoutItem_Click" Name="search_plugins"/>
                <MenuFlyoutItem Text="Logs" Click="MenuFlyoutItem_Click" Name="logs"/>
            </MenuBarItem>
        </MenuBar>

        <!-- Top-right: in-app MCP server toggle + config/help popout -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Spacing="2" Margin="0,0,8,0">
            <ToggleButton x:Name="McpToggle" Click="McpToggle_Click" Padding="8,2" MinHeight="28"
                          ToolTipService.ToolTip="In-app MCP server — lets an AI agent read &amp; drive the result viewer">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse x:Name="McpStatusDot" Width="9" Height="9" Fill="Gray"/>
                    <TextBlock Text="MCP" FontSize="13"/>
                </StackPanel>
            </ToggleButton>
            <Button x:Name="McpHelpButton" Click="McpHelpButton_Click" Padding="6,2" MinHeight="28"
                    ToolTipService.ToolTip="MCP server configuration &amp; how to connect">
                <FontIcon Glyph="&#xE946;" FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Status strip -->
        <Border Grid.Row="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" BorderThickness="0,1,0,1" BorderBrush="{ThemeResource SystemControlForegroundAltHighBrush}" Padding="12,4">
            <TextBlock x:Name="StatusStrip" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="Locations: 0 · Filters: 0 · Rules: 0 · Last run: —"/>
        </Border>

        <!-- Main content area with overlay spinner -->
        <Grid Grid.Row="2">
            <Frame x:Name="contentFrame" />
            <!-- Full-window overlay spinner for ETL inspection and quick actions -->
            <Grid x:Name="SpinnerPanel" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  AutomationProperties.Name="Operation in progress" AutomationProperties.LiveSetting="Polite">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
                    <ProgressRing x:Name="EtlSpinner" Width="64" Height="64" IsActive="False" AutomationProperties.Name="Working"/>

                    <!-- Structured step checklist (search→view flow). Fixed columns so the name,
                         metric, and percent line up across every step. -->
                    <ItemsControl x:Name="StepList" Margin="0,16,0,0" Visibility="Collapsed" MinWidth="480">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2" Opacity="{Binding Opacity}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="210"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               FontWeight="{Binding Weight}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextAlignment="Right" Margin="8,0,8,0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PercentText}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="SpinnerText" Text="Inspecting file..." Margin="0,16,0,0" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                    <Button x:Name="CancelQuickActionButton" Content="Cancel" Width="100" Margin="0,24,0,0" Click="CancelQuickActionButton_Click" Visibility="Collapsed"
                            AutomationProperties.Name="Cancel current operation"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
