<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="FindNeedleUX.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local1="using:FindNeedleUX.ViewObjects"
    mc:Ignorable="d"
    Title="Find Needle">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <MenuBar Grid.Row="0">
            <MenuBarItem x:Name="QuickMenu" Title="Quick">
                <!-- Items are built in code (BuildQuickMenu): Welcome + the welcome-page quick actions. -->
            </MenuBarItem>
            <MenuBarItem Title="Workspace">
                <MenuFlyoutItem Text="New" Click="MenuFlyoutItem_Click" Name="NewWorkspace" />
                <MenuFlyoutItem Text="Open..." Click="MenuFlyoutItem_Click" Name="OpenWorkspace"/>
                <MenuFlyoutItem Text="Save" Click="MenuFlyoutItem_Click" Name="SaveWorkspace"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Clear workspace" Click="MenuFlyoutItem_Click" Name="ClearWorkspace"/>
            </MenuBarItem>
            <MenuBarItem Title="Configure">
                <MenuFlyoutItem Text="Locations" Click="MenuFlyoutItem_Click" Name="search_location"/>
                <MenuFlyoutItem Text="Log Finder" Click="MenuFlyoutItem_Click" Name="log_finder"/>
                <MenuFlyoutItem Text="Connections" Click="MenuFlyoutItem_Click" Name="connections"/>
                <MenuFlyoutItem Text="Rules" Click="MenuFlyoutItem_Click" Name="rules"/>
            </MenuBarItem>
            <MenuBarItem Title="Run &amp; Results">
                <MenuFlyoutItem Text="Run Search" Click="MenuFlyoutItem_Click" Name="results_get"/>
                <MenuFlyoutItem Text="Results" Click="MenuFlyoutItem_Click" Name="results_viewnative"/>
                <MenuFlyoutItem Text="Processor Output" Click="MenuFlyoutItem_Click" Name="results_processoroutput"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Statistics &amp; timing (why so slow?)" Click="MenuFlyoutItem_Click" Name="results_statistics"/>
                <MenuFlyoutItem x:Name="RemapCsvMenuItem" Text="Remap CSV columns…" Click="RemapCsvMenuItem_Click" Visibility="Collapsed"/>
            </MenuBarItem>

            <MenuBarItem Title="Inspect">
                <MenuFlyoutItem Text="Inspect ETL" Click="MenuFlyoutItem_Click" Name="inspect_etl"/>
                <MenuFlyoutItem Text="Inspect Binary" Click="MenuFlyoutItem_Click" Name="inspect_binary"/>
            </MenuBarItem>

            <MenuBarItem Title="Settings">
                <MenuFlyoutItem Text="Preferences..." Click="MenuFlyoutItem_Click" Name="settings_resultviewer"/>
                <MenuFlyoutItem Text="Diagram Tools" Click="MenuFlyoutItem_Click" Name="diagramtools"/>
                <MenuFlyoutItem Text="Plugins" Click="MenuFlyoutItem_Click" Name="search_plugins"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="System Check" Click="MenuFlyoutItem_Click" Name="systeminfo"/>
                <MenuFlyoutItem Text="Logs" Click="MenuFlyoutItem_Click" Name="logs"/>
                <MenuFlyoutItem Text="About" Click="MenuFlyoutItem_Click" Name="about"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem Text="Preview first-run (new user)…" Click="MenuFlyoutItem_Click" Name="preview_new_user"
                                ToolTipService.ToolTip="Launch a second instance with an empty, throwaway profile — see the app as a brand-new user would. Your real settings/caches are untouched."/>
            </MenuBarItem>
        </MenuBar>

        <!-- Top-right: in-app MCP server toggle + config/help popout -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Spacing="2" Margin="0,0,8,0">
            <ToggleButton x:Name="McpToggle" Click="McpToggle_Click" Padding="8,2" MinHeight="28"
                          ToolTipService.ToolTip="In-app MCP server — lets an AI agent read &amp; drive the result viewer">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Ellipse x:Name="McpStatusDot" Width="9" Height="9" Fill="Gray"/>
                    <TextBlock Text="MCP" FontSize="13"/>
                </StackPanel>
            </ToggleButton>
            <Button x:Name="McpHelpButton" Click="McpHelpButton_Click" Padding="6,2" MinHeight="28"
                    ToolTipService.ToolTip="MCP server configuration &amp; how to connect">
                <FontIcon Glyph="&#xE946;" FontSize="14"/>
            </Button>
        </StackPanel>

        <!-- Status strip: clickable, iconed segments + a hide button. -->
        <Border x:Name="StatusStripBorder" Grid.Row="1" Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
                BorderThickness="0,1,0,1" BorderBrush="{ThemeResource SystemControlForegroundAltHighBrush}" Padding="8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="StatusSegments" Grid.Column="0" Orientation="Horizontal"
                            Spacing="2" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                    <Button x:Name="StatusEditButton" Click="EditStatusBar_Click"
                            Background="Transparent" BorderThickness="0" Padding="6,2" MinHeight="0"
                            ToolTipService.ToolTip="Choose what shows here">
                        <FontIcon Glyph="&#xE70F;" FontSize="11"/>
                    </Button>
                    <Button x:Name="StatusHideButton" Click="HideStatusStrip_Click"
                            Background="Transparent" BorderThickness="0" Padding="6,2" MinHeight="0"
                            ToolTipService.ToolTip="Hide status bar">
                        <FontIcon Glyph="&#xE711;" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content area with overlay spinner. AllowDrop here lets you drag log files/folders
             onto the viewer to open them (events bubble up from the hosted page in contentFrame). -->
        <Grid Grid.Row="2" AllowDrop="True"
              DragOver="Content_DragOver" DragLeave="Content_DragLeave" Drop="Content_Drop">
            <Frame x:Name="contentFrame" />
            <!-- Full-window overlay spinner for ETL inspection and quick actions -->
            <Grid x:Name="SpinnerPanel" Visibility="Collapsed" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                  AutomationProperties.Name="Operation in progress" AutomationProperties.LiveSetting="Polite">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
                    <ProgressRing x:Name="EtlSpinner" Width="64" Height="64" IsActive="False" AutomationProperties.Name="Working"/>
                    <ProgressBar x:Name="SpinnerBar" Width="320" IsIndeterminate="False" Visibility="Collapsed"
                                 AutomationProperties.Name="Working"/>
                    <!-- Animated robot loader (alternative to the spinner; chosen in settings). The
                         frame shown tracks the current search step. Box scales both square + wide art.
                         Wrapped in a framed card so it reads as an immersive panel. -->
                    <Border x:Name="SpinnerGifBorder" Visibility="Collapsed"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="12" Padding="16" Translation="0,0,32">
                        <Border.Shadow>
                            <ThemeShadow/>
                        </Border.Shadow>
                        <Image x:Name="SpinnerGif" MaxWidth="360" MaxHeight="240" Stretch="Uniform"
                               AutomationProperties.Name="Working"/>
                    </Border>

                    <!-- Structured step checklist (search→view flow). Fixed columns so the name,
                         metric, and percent line up across every step. -->
                    <ItemsControl x:Name="StepList" Margin="0,16,0,0" Visibility="Collapsed" MinWidth="480">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2,0,2" Opacity="{Binding Opacity}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="210"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="52"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                               FontWeight="{Binding Weight}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Detail}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextAlignment="Right" Margin="8,0,8,0" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3" Text="{Binding PercentText}" FontSize="13"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock x:Name="SpinnerText" Text="Inspecting file..." Margin="0,16,0,0" FontSize="18" Foreground="{ThemeResource TextFillColorPrimaryBrush}" HorizontalAlignment="Center"/>
                    <Button x:Name="CancelQuickActionButton" Content="Cancel" Width="100" Margin="0,24,0,0" Click="CancelQuickActionButton_Click" Visibility="Collapsed"
                            AutomationProperties.Name="Cancel current operation"/>
                </StackPanel>
            </Grid>

            <!-- Drag-and-drop overlay: shown while files are dragged over the viewer (hit-test off so
                 the drag events still reach the grid below). -->
            <Border x:Name="DropOverlay" Visibility="Collapsed" IsHitTestVisible="False" Margin="8"
                    Background="#CC101418" CornerRadius="6"
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" BorderThickness="3">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <FontIcon Glyph="&#xE896;" FontSize="44" Foreground="White"/>
                    <TextBlock Text="Drop log files to open" FontSize="20" FontWeight="SemiBold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Folders, .etl, .evtx, .log, .txt, .zip and more"
                               FontSize="13" Foreground="#CCFFFFFF" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
