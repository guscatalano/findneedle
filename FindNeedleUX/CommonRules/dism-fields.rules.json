{
  "schemaVersion": "2.0",
  "version": "1.0",
  "title": "DISM field extraction",
  "description": "Enrichment rules that pull ProcessId / ThreadId / Provider out of DISM log lines into real, queryable columns (requires field-extraction enrichment to be enabled).",
  "sections": [
    {
      "name": "DismFields",
      "description": "Extract PID/TID and the DISM component from the message into stored fields",
      "purpose": "enrichment",
      "providers": ["*"],
      "rules": [
        {
          "name": "dism-line",
          "field": "message",
          "match": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}(\\.\\d+)?",
            "set": { "Source": "DISM" },
            "strip": true
          }
        },
        {
          "name": "dism-component",
          "field": "message",
          "match": "\\bDISM\\b",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "DISM\\s+(?<comp>[A-Za-z][A-Za-z0-9 .]*?):",
            "set": { "TaskName": "{comp}" },
            "strip": true
          }
        },
        {
          "name": "dism-level",
          "field": "message",
          "match": ",\\s+(Info|Warning|Error|Verbose|Debug)\\b",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": ",\\s+(?<lvl>Info|Warning|Error|Verbose|Debug)\\b",
            "strip": true
          }
        },
        {
          "name": "dism-pid-tid",
          "field": "message",
          "match": "PID=\\d+\\s+TID=\\d+",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "PID=(?<pid>\\d+)\\s+TID=(?<tid>\\d+)",
            "set": { "ProcessId": "{pid}", "ThreadId": "{tid}" },
            "strip": true
          }
        },
        {
          "name": "dism-bracket-pid-tid",
          "field": "message",
          "match": "^\\[\\d+\\.\\d+\\]",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "^\\[(?<pid>\\d+)\\.(?<tid>\\d+)\\]",
            "set": { "ProcessId": "{pid}", "ThreadId": "{tid}", "Source": "DISM" },
            "strip": true
          }
        }
      ]
    }
  ]
}
