{
  "schemaVersion": "2.0",
  "version": "1.0",
  "title": "Windows Setup (Panther) field extraction",
  "description": "Makes Windows Setup / upgrade logs (Panther: setupact.log / setuperr.log) easier to read. They share DISM/CBS's '<timestamp>, <Level>  <Component>  <message>' shape, so this pulls the component into TaskName and the 'Result = 0x...' code into EventId, and strips the timestamp/level/component echo from the message. Requires field-extraction enrichment.",
  "sections": [
    {
      "name": "PantherFields",
      "description": "Pull the Setup component + result code into columns and clean the message",
      "purpose": "enrichment",
      "providers": ["*"],
      "rules": [
        {
          "name": "panther-line",
          "field": "message",
          "match": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\s+(Info|Warning|Error|Verbose|Debug)\\b",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}(\\.\\d+)?",
            "strip": true
          }
        },
        {
          "name": "panther-level",
          "field": "message",
          "match": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2},\\s+(Info|Warning|Error|Verbose|Debug)\\b",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": ",\\s+(?<lvl>Info|Warning|Error|Verbose|Debug)\\b",
            "strip": true
          }
        },
        {
          "name": "panther-component",
          "field": "message",
          "match": ",\\s+(?:Info|Warning|Error|Verbose|Debug)\\s+[A-Z][A-Za-z0-9]{1,9}\\s{2,}",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "(?<=,\\s{1,4}(?:Info|Warning|Error|Verbose|Debug)\\s{1,40})(?<comp>[A-Z][A-Za-z0-9]{1,9})(?=\\s{2,})",
            "set": { "TaskName": "{comp}" },
            "strip": true
          }
        },
        {
          "name": "panther-result",
          "field": "message",
          "match": "Result = 0x[0-9A-Fa-f]+",
          "enabled": true,
          "action": {
            "type": "extract",
            "pattern": "Result = (?<hr>0x[0-9A-Fa-f]+)",
            "set": { "EventId": "{hr}" },
            "strip": false
          }
        }
      ]
    }
  ]
}
