[
  {
    "File": "noise-filter.rules.json",
    "Name": "Hide debug / verbose noise",
    "Condition": { "Always": true }
  },
  {
    "File": "etw-crash-detection.rules.json",
    "Name": "ETW crash / fault highlighter",
    "Condition": { "Extensions": [".etl"], "SourceTypes": ["ETW"] }
  },
  {
    "File": "process-interaction.rules.json",
    "Name": "Process interaction diagram",
    "Condition": { "PathGlobs": ["*process-interaction*"] }
  },
  {
    "File": "process-interaction-uml.rules.json",
    "Name": "Process interaction diagram (UML participants)",
    "Hidden": true
  },
  {
    "File": "pii-filter.rules.json",
    "Name": "Filter out PII (hide lines)",
    "Condition": { "Always": true }
  },
  {
    "File": "pii-redact.rules.json",
    "Name": "Redact PII (mask in place)",
    "Condition": { "Always": true }
  },
  {
    "File": "dism-interaction.rules.json",
    "Name": "DISM interaction diagram",
    "Condition": { "PathGlobs": ["*dism*"] }
  },
  {
    "File": "dism-interaction-uml.rules.json",
    "Name": "DISM interaction diagram (UML participants)",
    "Hidden": true
  },
  {
    "File": "dism-fields.rules.json",
    "Name": "DISM field extraction (PID / TID / Provider)",
    "Condition": { "PathGlobs": ["*dism*"] }
  },
  {
    "File": "cbs-fields.rules.json",
    "Name": "CBS field extraction (Source / component / HRESULT)",
    "Condition": { "PathGlobs": ["*cbs*", "*CBS*"] }
  },
  {
    "File": "wu-fields.rules.json",
    "Name": "Windows Update message cleanup (strip task/level echo)",
    "Condition": { "Providers": ["WUTraceLogging"] }
  },
  {
    "File": "panther-fields.rules.json",
    "Name": "Windows Setup (Panther) field extraction (component / Result code)",
    "Condition": { "PathGlobs": ["*panther*", "*Panther*", "*setupact*", "*setuperr*"] }
  },
  {
    "File": "crash-filter.rules.json",
    "Name": "App crash / hang highlighter (show only failures)",
    "Condition": { "Providers": ["Application Error", "Application Hang", "Windows Error Reporting", ".NET Runtime"] }
  },
  {
    "File": "crash-report.rules.json",
    "Name": "App crash report (text report of every crash / hang)",
    "Condition": { "Providers": ["Application Error", "Application Hang", "Windows Error Reporting", ".NET Runtime"] }
  },
  {
    "File": "machine-power-filter.rules.json",
    "Name": "Machine power / boot timeline (show only power events)",
    "Condition": { "Providers": ["EventLog", "Microsoft-Windows-Kernel-General", "Microsoft-Windows-Kernel-Power", "Microsoft-Windows-Kernel-Boot"] }
  },
  {
    "File": "machine-power-timeline.rules.json",
    "Name": "Machine power / boot timeline (CSV report)",
    "Condition": { "Providers": ["EventLog", "Microsoft-Windows-Kernel-General", "Microsoft-Windows-Kernel-Power", "Microsoft-Windows-Kernel-Boot"] }
  }
]
