<Page
    x:Class="FindNeedleUX.Pages.NativeResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages.NativeResultViewer"
    xmlns:ctWinUI="using:CommunityToolkit.WinUI.UI.Controls"
    xmlns:i="using:Microsoft.Xaml.Interactions.Core"
    xmlns:interactivity="using:Microsoft.Xaml.Interactivity"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <!-- Level-based row colors -->
        <SolidColorBrush x:Key="LevelCatastrophicColor" Color="#FFB3B3" />
        <SolidColorBrush x:Key="LevelCriticalColor" Color="#FFCCCC" />
        <SolidColorBrush x:Key="LevelErrorColor" Color="#FFE1E1" />
        <SolidColorBrush x:Key="LevelWarningColor" Color="#FFF4CC" />
        <SolidColorBrush x:Key="LevelInfoColor" Color="Transparent" />
        <SolidColorBrush x:Key="LevelVerboseColor" Color="#F1F1F1" />
        <SolidColorBrush x:Key="LevelDebugColor" Color="#EEF3FF" />

        <!-- Row coloring is applied per-row via DataGrid.LoadingRow event in code-behind
             (WinUI 3 DataGrid doesn't support DataTriggers; LoadingRow is the canonical
             approach for the CommunityToolkit DataGrid). -->

        <!-- Row details template -->
        <DataTemplate x:Key="RowDetailsTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" 
                    CornerRadius="4" 
                    Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Log Entry Details" 
                               FontSize="16" 
                               FontWeight="SemiBold" />
                    
                    <Grid ColumnSpacing="8" RowSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock Text="Index:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Index}" />

                        <TextBlock Grid.Row="1" Text="Time:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Time}" />

                        <TextBlock Grid.Row="2" Text="Provider:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Provider}" />

                        <TextBlock Grid.Row="3" Text="TaskName:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TaskName}" />

                        <TextBlock Grid.Row="4" Text="Message:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5" Text="Source:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Source}" />

                        <TextBlock Grid.Row="6" Text="Level:" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Level}" FontWeight="SemiBold" />
                    </Grid>

                    <Button Content="Copy as JSON" 
                            Click="CopyJson_Click" 
                            Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="16">
            <StackPanel Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBox x:Name="SearchBox"
                             Header="Search results"
                             PlaceholderText="Search all columns... (Ctrl+F)"
                             Width="300"
                             Height="32"
                             AutomationProperties.Name="Search results"
                             AutomationProperties.HelpText="Filters all visible columns. Press Ctrl+F to focus."
                             TextChanged="SearchBox_TextChanged" />
                    
                    <Button Content="Columns" 
                            Click="ColumnsButton_Click"
                            Height="32" />
                    
                    <Button Content="Clear Filters" 
                            Click="ClearFiltersButton_Click"
                            Height="32" />
                    
                    <Button Content="Export CSV" 
                            Click="ExportCsvButton_Click"
                            Height="32" />
                </StackPanel>

                <!-- Time Range Filter -->
                <StackPanel x:Name="TimeRangePanel" 
                            Orientation="Horizontal" 
                            Spacing="8"
                            Visibility="Collapsed">
                    <TextBlock Text="Time Range:" 
                               VerticalAlignment="Center" 
                               FontSize="14" />
                    <CalendarDatePicker x:Name="FromDatePicker"
                                       Width="180"
                                       PlaceholderText="From" />
                    <TextBlock Text="→"
                               VerticalAlignment="Center" />
                    <CalendarDatePicker x:Name="ToDatePicker"
                                       Width="180"
                                       PlaceholderText="To" />
                    <Button Content="Apply" 
                            Click="ApplyTimeFilterButton_Click"
                            Height="32" />
                </StackPanel>

                <!-- Level Color Controls -->
                <StackPanel x:Name="LevelColorPanel" 
                            Orientation="Vertical" 
                            Spacing="8"
                            Margin="0,8,0,0">
                    <TextBlock Text="Level Colors:" 
                               VerticalAlignment="Center" 
                               FontSize="14" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.LevelColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="{Binding Key}" 
                                               VerticalAlignment="Center" 
                                               FontSize="12" />
                                    <Border Width="20" Height="20" 
                                            Background="{Binding Value}"
                                            CornerRadius="3"
                                            BorderBrush="Gray" 
                                            BorderThickness="1" />
                                    <Button Content="..."
                                            Width="32"
                                            Height="24"
                                            Click="LevelColorButton_Click"
                                            CommandParameter="{Binding Key}"
                                            AutomationProperties.Name="{Binding Key}"
                                            AutomationProperties.HelpText="Edit row color for this level" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Stats -->
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock x:Name="ResultsCountText" 
                               FontSize="14" 
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="TotalCountText" 
                               FontSize="14" 
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Filter Row -->
        <Border Grid.Row="1" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="8">
            <StackPanel x:Name="FilterRowPanel" />
        </Border>

        <!-- Data Grid -->
        <ctWinUI:DataGrid x:Name="ResultsGrid"
                          Grid.Row="2"
                          AutoGenerateColumns="False"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          IsReadOnly="True"
                          ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                          LoadingRow="ResultsGrid_LoadingRow"
                          RowDetailsTemplate="{StaticResource RowDetailsTemplate}"
                          RowDetailsVisibilityMode="VisibleWhenSelected"
                          SelectionMode="Single"
                          AutomationProperties.Name="Search results table">
            <ctWinUI:DataGrid.Columns>
                <ctWinUI:DataGridTextColumn Header="Index" 
                                            Binding="{Binding Index}"
                                            MinWidth="60" />
                <ctWinUI:DataGridTextColumn Header="Time" 
                                            Binding="{Binding Time}"
                                            MinWidth="160" />
                <ctWinUI:DataGridTextColumn Header="Provider" 
                                            Binding="{Binding Provider}"
                                            MinWidth="100" />
                <ctWinUI:DataGridTextColumn Header="TaskName" 
                                            Binding="{Binding TaskName}"
                                            MinWidth="120" />
                <ctWinUI:DataGridTextColumn Header="Message" 
                                            Binding="{Binding Message}"
                                            MinWidth="200" />
                <ctWinUI:DataGridTextColumn Header="Source" 
                                            Binding="{Binding Source}"
                                            MinWidth="100" />
                <ctWinUI:DataGridTextColumn Header="Level" 
                                            Binding="{Binding Level}"
                                            MinWidth="80" />
            </ctWinUI:DataGrid.Columns>
        </ctWinUI:DataGrid>

        <!-- Loading Indicator -->
        <Border x:Name="LoadingIndicator"
                Grid.Row="2"
                Background="{ThemeResource SystemControlPageBackgroundMediumAltMediumBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="24"
                CornerRadius="8"
                Visibility="Collapsed"
                AutomationProperties.Name="Loading results"
                AutomationProperties.LiveSetting="Polite">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <ProgressRing Width="48" Height="48" IsActive="True" AutomationProperties.Name="Loading"/>
                <TextBlock Text="Loading results..."
                           FontSize="16"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <!-- Column Visibility Toggle Panel -->
        <Border x:Name="ColumnVisibilityPanel"
                Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                VerticalAlignment="Top"
                HorizontalAlignment="Right"
                Margin="0,60,20,0"
                Visibility="Collapsed"
                Shadow="{ThemeResource SystemDropShadowBrush}">
            <StackPanel Spacing="8">
                <TextBlock Text="Column Visibility" 
                           FontSize="14" 
                           FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{x:Bind ViewModel.ColumnVisibility}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Key}"
                                      IsChecked="{Binding Value, Mode=TwoWay}"
                                      Checked="ColumnVisibilityCheckBox_Checked"
                                      Unchecked="ColumnVisibilityCheckBox_Unchecked"
                                      Margin="0,4,0,4" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="Close" 
                        Click="CloseColumnPanelButton_Click"
                        Margin="0,8,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
