<Page
    x:Class="FindNeedleUX.Pages.NativeResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages.NativeResultViewer"
    xmlns:pages="using:FindNeedleUX.Pages"
    xmlns:ctWinUI="using:CommunityToolkit.WinUI.UI.Controls"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:HexToBrushConverter x:Key="HexToBrush"/>
        <local:TimeFormatConverter x:Key="TimeFmt"/>
        <pages:BoolToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Row details panel -->
        <DataTemplate x:Key="RowDetailsTemplate">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="4" Padding="16" Margin="4">
                <StackPanel Spacing="6">
                    <TextBlock Text="Log entry details" FontSize="14" FontWeight="SemiBold"/>
                    <Grid ColumnSpacing="8" RowSpacing="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            <RowDefinition/><RowDefinition/><RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Index"    FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Index}" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="1" Text="Time"     FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Time}" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="2" Text="Provider" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Provider}" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="3" Text="TaskName" FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding TaskName}" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="4" Text="Message"  FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="5" Text="Source"   FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding Source}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        <TextBlock Grid.Row="6" Text="Level"    FontWeight="SemiBold"/>
                        <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding Level}" FontWeight="SemiBold" IsTextSelectionEnabled="True"/>
                    </Grid>
                    <Button Content="Copy as JSON" Click="CopyJson_Click" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar (full width) -->
            <RowDefinition Height="Auto"/>  <!-- Decode/explain banner -->
            <RowDefinition Height="*"/>     <!-- Body: optional left filter pane + main content -->
        </Grid.RowDefinitions>

        <!-- Banners (Grid.Row 1): streaming "still loading" + the why-is-this-empty decode banner. -->
        <StackPanel Grid.Row="1">
            <!-- Rule output files (diagrams/exports) were generated by this search. Custom Border (not
                 InfoBar) so the spacing is exactly what we set — no mystery template gaps. Collapsed
                 by default; shown via UpdateOutputFilesBanner(). -->
            <Border x:Name="OutputFilesBanner" Visibility="Collapsed"
                    Margin="0" Padding="12,8" CornerRadius="0"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                    BorderThickness="0">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="16" VerticalAlignment="Center"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                    <TextBlock x:Name="OutputFilesBannerText" Grid.Column="1" VerticalAlignment="Center"
                               TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                               Text="Output files generated"/>
                    <Button Grid.Column="2" Content="View output files" Click="ViewOutputFiles_Click"/>
                    <Button Grid.Column="3" Click="DismissOutputFilesBanner_Click"
                            Background="Transparent" BorderThickness="0" Padding="6"
                            ToolTipService.ToolTip="Dismiss">
                        <FontIcon Glyph="&#xE711;" FontSize="12"/>
                    </Button>
                </Grid>
            </Border>

            <!-- Shown while a streaming search is still producing rows; count keeps rising. -->
            <InfoBar x:Name="StreamingBanner" IsClosable="False" Severity="Informational"
                     IsIconVisible="False" Margin="12,8,12,0"
                     Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                     IsOpen="{x:Bind ViewModel.IsStreaming, Mode=OneWay}">
                <InfoBar.Content>
                    <!-- Single compact row: animated loader icon · status text · Stop. -->
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,2,0,6">
                        <Grid Width="28" Height="28" VerticalAlignment="Center">
                            <Image x:Name="StreamGif" Stretch="Uniform" Visibility="Collapsed"/>
                            <ProgressRing x:Name="StreamRing" Width="20" Height="20" IsActive="True" Visibility="Collapsed"/>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.StreamingBannerText, Mode=OneWay}"
                                   VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                        <Button Content="Refresh results" Click="RefreshResults_Click" VerticalAlignment="Center"
                                Visibility="{x:Bind ViewModel.PendingRowsVisibility, Mode=OneWay}"
                                ToolTipService.ToolTip="Fold newly-loaded rows into your filtered view (paused while searching during load)"/>
                        <Button Content="Stop loading" Click="StopStreamingButton_Click" VerticalAlignment="Center"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- Why-is-this-empty banner (e.g. WPP ETL with missing symbols). Hidden unless set. -->
            <InfoBar x:Name="DecodeBanner" IsOpen="False" IsClosable="True" Visibility="Collapsed"
                     Severity="Warning" Margin="12,8,12,0">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,8">
                        <Button x:Name="DecodeBannerSettings" Content="Open WPP symbol settings"
                                Click="DecodeBannerAction_Click"/>
                        <Button x:Name="DecodeBannerForce" Content="Decode anyway" Click="DecodeAnyway_Click"
                                ToolTipService.ToolTip="Decode whatever can be read, even if most events are unformatted garbage"/>
                        <Button x:Name="DecodeBannerCopy" Content="Copy" Click="DecodeBannerCopy_Click"
                                ToolTipService.ToolTip="Copy the missing TMF GUIDs and error detail to clipboard"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="0" Padding="12,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
          <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" Width="280" Height="32"
                         PlaceholderText="Search all columns... (Ctrl+F)"
                         TextChanged="SearchBox_TextChanged"
                         KeyDown="SearchBox_KeyDown"
                         GotFocus="SearchBox_GotFocus"
                         AutomationProperties.Name="Search results"/>
                <!-- Spins while a search runs off the UI thread (so the window never freezes). -->
                <ProgressRing x:Name="SearchBusyRing" Width="16" Height="16"
                              IsActive="False" Visibility="Collapsed"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="Searching"/>
                <!-- Shown when the viewer is in Enter-to-search mode (large/slow log) so the user
                     knows mid-typing doesn't search. Hidden in live mode. -->
                <TextBlock x:Name="SearchHint" VerticalAlignment="Center" FontSize="11"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Visibility="Collapsed"
                           AutomationProperties.Name="Search submit hint"/>

                <Button Content="Columns ▾" Height="32"
                        AutomationProperties.Name="Toggle column visibility">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Spacing="6" MinWidth="180">
                                <TextBlock Text="Columns" FontWeight="SemiBold" FontSize="13"/>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Columns}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="local:ColumnEntry">
                                            <CheckBox Content="{x:Bind Name}"
                                                      IsChecked="{x:Bind IsVisible, Mode=TwoWay}"
                                                      Margin="0,2,0,2"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <DropDownButton x:Name="ExportButton" Content="Export" Height="32"
                                AutomationProperties.Name="Export results">
                    <DropDownButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Export as CSV"  Click="ExportCsv_Click"/>
                            <MenuFlyoutItem Text="Export as JSON" Click="ExportJson_Click"/>
                            <MenuFlyoutItem Text="Export as XML"  Click="ExportXml_Click"/>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
                <Button x:Name="SourcesButton" Click="ShowLoadedSources_Click" Height="32"
                        AutomationProperties.Name="Show loaded locations and rules"
                        ToolTipService.ToolTip="See which locations and rule files this search loaded">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="SourcesWarnGlyph" Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="12" VerticalAlignment="Center" Visibility="Collapsed"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        <TextBlock Text="Sources"/>
                    </StackPanel>
                </Button>
                <ToggleButton x:Name="FiltersToggle" Height="32"
                              IsChecked="True"
                              Click="FiltersToggle_Click"
                              AutomationProperties.Name="Show or hide filters">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock x:Name="FiltersToggleGlyph" Text="▾" FontSize="11"/>
                        <TextBlock Text="Filters"/>
                    </StackPanel>
                </ToggleButton>

                <!-- View: rule-filter toggle, row-detail mode, and filter-pane dock, grouped. -->
                <Button Content="View ▾" Height="32" AutomationProperties.Name="View options"
                        ToolTipService.ToolTip="Row details, filter pane position, and rule filtering">
                    <Button.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <ToggleMenuFlyoutItem x:Name="RuleFilterToggle"
                                                  Text="Rule filter — hide rows excluded by active rules"
                                                  IsEnabled="False" Click="RuleFilterToggle_Click"/>
                            <MenuFlyoutSeparator/>
                            <MenuFlyoutSubItem Text="Row details">
                                <RadioMenuFlyoutItem x:Name="DetailsInrowItem"  Text="Inrow — click a row to expand"          GroupName="detailsMode" Click="DetailsModeInrow_Click"/>
                                <RadioMenuFlyoutItem x:Name="DetailsPanelItem"  Text="Bottom panel — docked below the grid"   GroupName="detailsMode" Click="DetailsModeBottomPanel_Click"/>
                                <RadioMenuFlyoutItem x:Name="DetailsPopupItem"  Text="Popup — double-click a row for a dialog" GroupName="detailsMode" Click="DetailsModePopup_Click"/>
                            </MenuFlyoutSubItem>
                            <MenuFlyoutSubItem Text="Filter pane">
                                <RadioMenuFlyoutItem x:Name="DockTopItem"  Text="Filters on top"  GroupName="filterDock" Click="FilterDockTop_Click"/>
                                <RadioMenuFlyoutItem x:Name="DockLeftItem" Text="Filters on left" GroupName="filterDock" Click="FilterDockLeft_Click"/>
                            </MenuFlyoutSubItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>

                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           VerticalAlignment="Center" Margin="16,0,0,0"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                <!-- Filter performance breakdown (what made the last filter/search slow). -->
                <Button x:Name="FilterPerfButton" Height="32" Margin="8,0,0,0" Padding="8,0,8,0"
                        Content="{x:Bind ViewModel.LastFilterSummary, Mode=OneWay}"
                        ToolTipService.ToolTip="Filter performance breakdown">
                    <Button.Flyout>
                        <Flyout>
                            <StackPanel Spacing="6" MinWidth="300">
                                <TextBlock Text="Filter performance" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind ViewModel.LastFilterBreakdown, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Tip: if the index is still building, text search uses a slower scan until it finishes."
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>

                <!-- Streaming indicator + Stop button. Visible only while the source's producer
                     (the running search task) is still writing rows. Collapses cleanly when the
                     search finishes or the user clicks Stop. -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            Visibility="{x:Bind ViewModel.IsStreaming, Mode=OneWay}">
                    <ProgressRing IsActive="True" Width="16" Height="16"/>
                    <TextBlock Text="loading…" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Stop" Height="28" Click="StopStreamingButton_Click"
                            AutomationProperties.Name="Stop loading"/>
                </StackPanel>

                <!-- Search-index build indicator + Cancel. Visible while the FTS index builds
                     (lazy/background modes); substring search uses the slower scan until it clears. -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            Visibility="{x:Bind ViewModel.IsIndexing, Mode=OneWay}">
                    <ProgressRing IsActive="True" Width="16" Height="16"/>
                    <TextBlock Text="{x:Bind ViewModel.IndexStatusText, Mode=OneWay}" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Button Content="Cancel" Height="28" Click="CancelIndexingButton_Click"
                            AutomationProperties.Name="Cancel building search index"/>
                </StackPanel>
            </StackPanel>

            <!-- Overflow: rarely-used Help + Settings, pinned right. -->
            <Button Grid.Column="1" x:Name="OverflowButton" Height="32" VerticalAlignment="Center"
                    AutomationProperties.Name="More" ToolTipService.ToolTip="More">
                <FontIcon Glyph="&#xE712;" FontSize="14"/>
                <Button.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuFlyoutItem Text="Help" Click="HelpButton_Click"/>
                        <MenuFlyoutItem Text="Settings…" Click="SettingsButton_Click"/>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
          </Grid>
        </Border>

        <!-- Body: an optional left-docked filter pane (Column 0) beside the main content (Column 1).
             The single FiltersPanel is re-parented between LeftFilterHost and TopFilterHost in code
             (RefreshFilterLayout) per the dock setting; its inner rows switch horizontal/vertical. -->
        <Grid Grid.Row="2" x:Name="BodyGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftFilterColumn" Width="Auto"/>  <!-- left filter pane (0 unless docked left; user-resizable) -->
                <ColumnDefinition Width="Auto"/>                            <!-- resize splitter (shown only in left dock) -->
                <ColumnDefinition Width="*"/>                              <!-- main content -->
            </Grid.ColumnDefinitions>

            <!-- Left-dock host: fills the resizable column; scrolls when the filters are taller than the viewport. -->
            <ScrollViewer x:Name="LeftFilterHost" Grid.Column="0" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0"/>

            <!-- Drag-to-resize handle between the filter pane and the results (left dock only). -->
            <Border x:Name="FilterPaneSplitter" Grid.Column="1" Width="6" Visibility="Collapsed"
                    Background="Transparent"
                    PointerEntered="FilterPaneSplitter_PointerEntered" PointerExited="FilterPaneSplitter_PointerExited"
                    PointerPressed="FilterPaneSplitter_PointerPressed" PointerMoved="FilterPaneSplitter_PointerMoved"
                    PointerReleased="FilterPaneSplitter_PointerReleased" PointerCaptureLost="FilterPaneSplitter_PointerCaptureLost"
                    ToolTipService.ToolTip="Drag to resize the filter pane"/>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Top-dock filter host -->
                    <RowDefinition Height="*"/>     <!-- Grid + overlays -->
                    <RowDefinition Height="Auto"/>  <!-- Details panel -->
                    <RowDefinition Height="Auto"/>  <!-- Pagination bar -->
                </Grid.RowDefinitions>

                <!-- Top-dock host (default). FiltersPanel lives here initially. -->
                <ContentControl x:Name="TopFilterHost" Grid.Row="0" HorizontalContentAlignment="Stretch">

        <!-- Collapsible filter content: time range / per-column filter row / level chips. -->
        <Border x:Name="FiltersPanel"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <!-- Time range -->
                <Border Padding="12,6"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <StackPanel x:Name="TimeRowPanel" Orientation="Vertical" Spacing="6">
                        <!-- Quick relative presets (anchored to the log's latest event) + Custom toggle.
                             WrapPanelLite so the chips flow onto more lines in a narrow (left-dock) pane
                             instead of falling off the edge. -->
                        <local:WrapPanelLite x:Name="TimePresetPanel" HorizontalSpacing="6" VerticalSpacing="6">
                            <TextBlock Text="Time:" VerticalAlignment="Center" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <ToggleButton Content="15m" Tag="15"    Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="Last 15 minutes of the log"/>
                            <ToggleButton Content="1h"  Tag="60"    Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="Last hour of the log"/>
                            <ToggleButton Content="6h"  Tag="360"   Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="Last 6 hours of the log"/>
                            <ToggleButton Content="24h" Tag="1440"  Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="Last 24 hours of the log"/>
                            <ToggleButton Content="7d"  Tag="10080" Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="Last 7 days of the log"/>
                            <ToggleButton x:Name="TimePresetAll" Content="All" Tag="0" IsChecked="True" Height="28" FontSize="12" Padding="8,0" Click="TimePreset_Click" ToolTipService.ToolTip="No time filter (whole log)"/>
                            <ToggleButton x:Name="CustomTimeToggle" Content="Custom ▾" Height="28" FontSize="12" Padding="8,0" Click="CustomTimeToggle_Click" ToolTipService.ToolTip="Pick an exact From/To date and time"/>
                        </local:WrapPanelLite>
                        <!-- Custom absolute range. Each bound stacks its date over its time so the 24h
                             TimePicker keeps enough width to show BOTH hour and minute (it clips to just
                             the hour when squeezed). The groups wrap to fit a narrow / resized pane. -->
                        <local:WrapPanelLite x:Name="CustomTimePanel" HorizontalSpacing="12" VerticalSpacing="8" Visibility="Collapsed">
                            <StackPanel Orientation="Vertical" Spacing="4">
                                <TextBlock Text="From" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <CalendarDatePicker x:Name="FromDatePicker" Width="170" PlaceholderText="From date"
                                                    DateChanged="FromDatePicker_DateChanged"/>
                                <DropDownButton x:Name="FromTimeButton" Width="170" HorizontalContentAlignment="Stretch"
                                                Content="Time: any"
                                                ToolTipService.ToolTip="Start time (optional). Empty = start of day; a time alone filters that minute on the log's day.">
                                    <DropDownButton.Flyout>
                                        <Flyout>
                                            <StackPanel Spacing="10" MinWidth="240">
                                                <TextBlock Text="From time" FontWeight="SemiBold"/>
                                                <TimePicker x:Name="FromTimePicker" ClockIdentifier="24HourClock" MinuteIncrement="1"
                                                            SelectedTimeChanged="FromTimePicker_SelectedTimeChanged"/>
                                                <Button Content="Clear time" Click="ClearFromTime_Click" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>
                            <StackPanel Orientation="Vertical" Spacing="4">
                                <TextBlock Text="To" FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <CalendarDatePicker x:Name="ToDatePicker" Width="170" PlaceholderText="To date"
                                                    DateChanged="ToDatePicker_DateChanged"/>
                                <DropDownButton x:Name="ToTimeButton" Width="170" HorizontalContentAlignment="Stretch"
                                                Content="Time: any"
                                                ToolTipService.ToolTip="End time (optional). Empty = end of day; a set time includes that whole minute.">
                                    <DropDownButton.Flyout>
                                        <Flyout>
                                            <StackPanel Spacing="10" MinWidth="240">
                                                <TextBlock Text="To time" FontWeight="SemiBold"/>
                                                <TimePicker x:Name="ToTimePicker" ClockIdentifier="24HourClock" MinuteIncrement="1"
                                                            SelectedTimeChanged="ToTimePicker_SelectedTimeChanged"/>
                                                <Button Content="Clear time" Click="ClearToTime_Click" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Flyout>
                                    </DropDownButton.Flyout>
                                </DropDownButton>
                            </StackPanel>
                            <Button Content="Clear" Click="ClearTimeRange_Click" Height="32" VerticalAlignment="Bottom"/>
                        </local:WrapPanelLite>
                    </StackPanel>
                </Border>

                <!-- Per-column filter row -->
                <Border Padding="12,6"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                    <StackPanel x:Name="FilterRowPanel" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Filter:" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <!-- Toggle: free-text boxes vs "known value" dropdowns for Provider/TaskName/Source. -->
                        <ToggleButton x:Name="ShowKnownToggle" Height="28" FontSize="12" Padding="8,0"
                                      Content="Known ▾" Checked="ShowKnownToggle_Toggled" Unchecked="ShowKnownToggle_Toggled"
                                      ToolTipService.ToolTip="Pick from the values actually present (Provider / TaskName / Source) instead of typing."/>
                        <!-- Provider: text box OR known-value combo (one visible at a time) -->
                        <TextBox x:Name="ProviderFilterBox" Width="120" Height="28" FontSize="12"
                                 PlaceholderText="Provider…" TextChanged="ProviderFilter_TextChanged"/>
                        <ComboBox x:Name="ProviderFilterCombo" Width="160" Height="28" FontSize="12" Visibility="Collapsed"
                                  PlaceholderText="Provider (known)…" SelectionChanged="ProviderFilterCombo_SelectionChanged"/>
                        <DropDownButton x:Name="ProviderFilterMulti" Height="28" FontSize="12" Visibility="Collapsed"
                                        Content="Provider (any)">
                            <DropDownButton.Flyout>
                                <Flyout>
                                    <ListView x:Name="ProviderFilterMultiList" SelectionMode="Multiple"
                                              MinWidth="240" MaxHeight="340"
                                              SelectionChanged="ProviderFilterMultiList_SelectionChanged"/>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <TextBox x:Name="TaskNameFilterBox" Width="140" Height="28" FontSize="12"
                                 PlaceholderText="TaskName…" TextChanged="TaskNameFilter_TextChanged"/>
                        <ComboBox x:Name="TaskNameFilterCombo" Width="160" Height="28" FontSize="12" Visibility="Collapsed"
                                  PlaceholderText="TaskName (known)…" SelectionChanged="TaskNameFilterCombo_SelectionChanged"/>
                        <DropDownButton x:Name="TaskNameFilterMulti" Height="28" FontSize="12" Visibility="Collapsed"
                                        Content="TaskName (any)">
                            <DropDownButton.Flyout>
                                <Flyout>
                                    <ListView x:Name="TaskNameFilterMultiList" SelectionMode="Multiple"
                                              MinWidth="240" MaxHeight="340"
                                              SelectionChanged="TaskNameFilterMultiList_SelectionChanged"/>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <TextBox x:Name="MessageFilterBox" Width="220" Height="28" FontSize="12"
                                 PlaceholderText="Message…" TextChanged="MessageFilter_TextChanged"/>
                        <TextBox x:Name="SourceFilterBox" Width="140" Height="28" FontSize="12"
                                 PlaceholderText="Source…" TextChanged="SourceFilter_TextChanged"/>
                        <ComboBox x:Name="SourceFilterCombo" Width="160" Height="28" FontSize="12" Visibility="Collapsed"
                                  PlaceholderText="Source (known)…" SelectionChanged="SourceFilterCombo_SelectionChanged"/>
                        <DropDownButton x:Name="SourceFilterMulti" Height="28" FontSize="12" Visibility="Collapsed"
                                        Content="Source (any)">
                            <DropDownButton.Flyout>
                                <Flyout>
                                    <ListView x:Name="SourceFilterMultiList" SelectionMode="Multiple"
                                              MinWidth="240" MaxHeight="340"
                                              SelectionChanged="SourceFilterMultiList_SelectionChanged"/>
                                </Flyout>
                            </DropDownButton.Flyout>
                        </DropDownButton>
                        <ComboBox x:Name="LevelFilterCombo" Width="140" Height="28" FontSize="12"
                                  PlaceholderText="Level (all)"
                                  ItemsSource="{x:Bind ViewModel.KnownLevelNames, Mode=OneWay}"
                                  SelectionChanged="LevelFilterCombo_SelectionChanged"/>
                        <Button Content="Reset row" Click="ResetColumnFilters_Click" Height="28" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Level color chips: per-level swatch + count + click-to-edit-color -->
                <Border Padding="12,6">
                    <StackPanel x:Name="LevelsRowPanel" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                        <TextBlock Text="Levels:" VerticalAlignment="Center" FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <ItemsControl ItemsSource="{x:Bind ViewModel.Levels}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- Reflows the chips so they wrap in the narrow left-docked pane. -->
                                    <local:WrapPanelLite HorizontalSpacing="6" VerticalSpacing="6"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:LevelEntry">
                                    <Button Click="LevelChip_Click" Tag="{x:Bind Level}"
                                            Padding="8,3" MinHeight="0" FontSize="12"
                                            AutomationProperties.Name="Edit color for level">
                                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                            <Border Width="12" Height="12" CornerRadius="2" BorderThickness="1"
                                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                    Background="{x:Bind HexColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"/>
                                            <TextBlock Text="{x:Bind Level}" FontSize="12"/>
                                            <TextBlock Text="{x:Bind Count, Mode=OneWay}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <!-- Clear every filter at once (search box, per-column, time range, level). -->
                <Border Padding="12,6"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
                    <Button Content="Clear all filters" Click="ClearFiltersButton_Click"
                            Height="28" FontSize="12"
                            AutomationProperties.Name="Clear all filters"/>
                </Border>
            </StackPanel>
        </Border>
                </ContentControl>

                <!-- DataGrid + overlays -->
                <Grid Grid.Row="1">
            <!-- RowHeight + explicit column widths matter a lot for scroll perf:
                 with both unset, DataGrid measures every visible cell on every scroll frame
                 (because Message text length varies). Fixing the row height makes the row
                 virtualizer assume uniform geometry; fixing column widths skips per-cell
                 measure on scroll. RowHeight=28 truncates long Message text in the cell, but
                 the full text is still visible in the row-details panel and the More dialog. -->
            <!--
                Scroll perf: every column is fixed-width (no Star sizing) and explicit
                EnableRow/ColumnVirtualization so the DataGrid never recomputes column
                geometry while inertia-scrolling. The Message column is a fixed 800px instead
                of "*" because Star sizing forces a layout pass each time the scrollbar's
                visibility flips. RowHeight=26 keeps geometry uniform.
                Long Message text is clipped at the cell edge — the row-details panel and
                the "More" dialog still show it in full.
            -->
            <ctWinUI:DataGrid x:Name="ResultsGrid"
                              AutoGenerateColumns="False"
                              CanUserReorderColumns="True"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              RowHeight="26"
                              HeadersVisibility="All"
                              RowHeaderWidth="22"
                              GridLinesVisibility="None"
                              ItemsSource="{x:Bind ViewModel.Results, Mode=OneWay}"
                              LoadingRow="ResultsGrid_LoadingRow"
                              Sorting="ResultsGrid_Sorting"
                              RightTapped="ResultsGrid_RightTapped"
                              DoubleTapped="ResultsGrid_DoubleTapped"
                              SelectionChanged="ResultsGrid_SelectionChanged"
                              RowDetailsTemplate="{StaticResource RowDetailsTemplate}"
                              RowDetailsVisibilityMode="VisibleWhenSelected"
                              SelectionMode="Extended"
                              ClipboardCopyMode="IncludeHeader"
                              AutomationProperties.Name="Search results">
                <ctWinUI:DataGrid.Columns>
                    <ctWinUI:DataGridTextColumn Header="Index"    Binding="{Binding Index}"    Width="70"/>
                    <ctWinUI:DataGridTextColumn Header="Time"     Binding="{Binding LogTime, Converter={StaticResource TimeFmt}}" Width="160"/>
                    <ctWinUI:DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="120"/>
                    <ctWinUI:DataGridTextColumn Header="TaskName" Binding="{Binding TaskName}" Width="140"/>
                    <ctWinUI:DataGridTextColumn Header="Message"  Binding="{Binding Message}"  Width="800"/>
                    <ctWinUI:DataGridTextColumn Header="Source"   Binding="{Binding Source}"   Width="140"/>
                    <ctWinUI:DataGridTextColumn Header="Level"    Binding="{Binding Level}"    Width="90"/>
                    <ctWinUI:DataGridTextColumn Header="ProcessId"  Binding="{Binding ProcessId}"  Width="80"/>
                    <ctWinUI:DataGridTextColumn Header="ProcessName" Binding="{Binding ProcessName}" Width="140"/>
                    <ctWinUI:DataGridTextColumn Header="ThreadId"   Binding="{Binding ThreadId}"   Width="80"/>
                    <ctWinUI:DataGridTextColumn Header="ActivityId" Binding="{Binding ActivityId}" Width="240"/>
                    <ctWinUI:DataGridTextColumn Header="EventId"    Binding="{Binding EventId}"    Width="80"/>
                    <ctWinUI:DataGridTextColumn Header="OpCode"     Binding="{Binding OpCode}"     Width="100"/>
                    <ctWinUI:DataGridTextColumn Header="Keywords"   Binding="{Binding Keywords}"   Width="140"/>
                    <ctWinUI:DataGridTextColumn Header="RelatedActivityId" Binding="{Binding RelatedActivityId}" Width="240"/>
                    <ctWinUI:DataGridTextColumn Header="Channel"    Binding="{Binding Channel}"    Width="120"/>
                    <ctWinUI:DataGridTextColumn Header="ProviderGuid" Binding="{Binding ProviderGuid}" Width="240"/>
                    <ctWinUI:DataGridTextColumn Header="RecordId"   Binding="{Binding RecordId}"   Width="90"/>
                </ctWinUI:DataGrid.Columns>
            </ctWinUI:DataGrid>

            <!-- Loading overlay -->
            <Border x:Name="LoadingOverlay" Visibility="Collapsed"
                    Background="#80000000"
                    AutomationProperties.LiveSetting="Polite">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <ProgressRing Width="48" Height="48" IsActive="True"/>
                    <TextBlock x:Name="LoadingOverlayText" Text="Loading results..." Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Empty-state overlay: shown when a finished load has zero rows, so the grid never just
                 sits blank. Adapts: "no rows at all" vs "filters hid everything" (offers Clear filters). -->
            <Border x:Name="EmptyOverlay" Visibility="Collapsed"
                    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
                    AutomationProperties.LiveSetting="Polite">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8" MaxWidth="440">
                    <FontIcon Glyph="&#xE7BA;" FontSize="32" HorizontalAlignment="Center"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock x:Name="EmptyOverlayTitle" Text="No results" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyOverlayText" TextWrapping="Wrap" TextAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="This search returned no rows."/>
                    <Button x:Name="EmptyOverlayClearFilters" Content="Clear filters" HorizontalAlignment="Center"
                            Margin="0,4,0,0" Visibility="Collapsed" Click="ClearFiltersButton_Click"/>
                </StackPanel>
            </Border>

        </Grid>

        <!-- Details panel (Grid.Row=3). The DataGrid's per-row expandable details are disabled
             when this panel is shown — the two ways of viewing details are mutually exclusive.
             Collapsed when DetailsPanelToggle is off (the default "Inrow" mode).
             The Border's Height is set in code-behind from ResultsViewerSettings and updated
             when the user drags the resize grip at the top. The inner grid is Auto/Auto/*, so
             the ScrollViewer takes whatever vertical space remains after the grip + header and
             shows a scrollbar when content overflows it. -->
        <Border x:Name="DetailsPanel" Grid.Row="2" Visibility="Collapsed"
                Height="240"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Resize grip -->
                    <RowDefinition Height="Auto"/>  <!-- Header bar (title + Copy / ✕) -->
                    <RowDefinition Height="*"/>     <!-- Content (fills remaining height) -->
                </Grid.RowDefinitions>

                <!-- Resize grip. Click & drag vertically to change the panel's height. Tracks
                     pointer on the page (not just on the grip element) so the user can drag
                     past the grip's bounds without losing capture. -->
                <Border x:Name="DetailsPanelResizer" Grid.Row="0"
                        Height="8" Background="Transparent"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        PointerEntered="DetailsPanelResizer_PointerEntered"
                        PointerExited="DetailsPanelResizer_PointerExited"
                        PointerPressed="DetailsPanelResizer_PointerPressed"
                        PointerMoved="DetailsPanelResizer_PointerMoved"
                        PointerReleased="DetailsPanelResizer_PointerReleased"
                        PointerCaptureLost="DetailsPanelResizer_PointerCaptureLost"
                        ToolTipService.ToolTip="Drag to resize">
                    <Rectangle Width="48" Height="3"
                               RadiusX="1.5" RadiusY="1.5"
                               Fill="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="1" Padding="12,6"
                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TextBlock Text="Selected row details" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" Spacing="6"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="DetailsFieldsButton" Content="Fields ▾" Click="DetailsFields_Click"
                                Height="28" FontSize="12"
                                ToolTipService.ToolTip="Choose which fields are shown"/>
                        <Button Content="Copy as JSON" Click="DetailsPanelCopyJson_Click"
                                Height="28" FontSize="12"/>
                        <Button Content="Copy as CSV"  Click="DetailsPanelCopyCsv_Click"
                                Height="28" FontSize="12"/>
                        <Button Content="Copy as XML"  Click="DetailsPanelCopyXml_Click"
                                Height="28" FontSize="12"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2" Padding="12,8"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid x:Name="DetailsPanelGrid" ColumnSpacing="12" RowSpacing="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="DetailsPanelPlaceholder"
                                   Text="Select a row above to see its full details here."
                                   Grid.ColumnSpan="2"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontStyle="Italic" Margin="0,4,0,4"/>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Pagination bar -->
        <Border Grid.Row="3" Padding="12,6"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <!-- The four navigation buttons grouped together: « First ‹ Prev  Next › Last » -->
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="« First" Click="FirstPage_Click" Height="28" FontSize="12"/>
                    <Button Content="‹ Prev"  Click="PrevPage_Click"  Height="28" FontSize="12"/>
                    <Button Content="Next ›"  Click="NextPage_Click"  Height="28" FontSize="12"/>
                    <Button Content="Last »"  Click="LastPage_Click"  Height="28" FontSize="12"/>
                </StackPanel>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="8,0,0,0">
                    <Run Text="Page "/>
                    <Run Text="{x:Bind ViewModel.CurrentPage, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{x:Bind ViewModel.TotalPages, Mode=OneWay}"/>
                    <Run Text="  ·  "/>
                    <Run Text="{x:Bind ViewModel.PageRangeText, Mode=OneWay}"/>
                    <Run Text=" of "/>
                    <Run Text="{x:Bind ViewModel.TotalFilteredCount, Mode=OneWay}"/>
                </TextBlock>
                <TextBox x:Name="PageJumpBox" Width="60" Height="28" FontSize="12"
                         PlaceholderText="# go to" KeyDown="PageJumpBox_KeyDown"
                         AutomationProperties.Name="Jump to page"/>
                <Button Content="Go" Click="PageJump_Click" Height="28" FontSize="12"/>
                <TextBlock Text="Page size:" VerticalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="16,0,0,0"/>
                <ComboBox x:Name="PageSizeCombo" Width="80" Height="28" FontSize="12"
                          SelectionChanged="PageSizeCombo_SelectionChanged"
                          AutomationProperties.Name="Page size">
                    <ComboBoxItem Content="50"   Tag="50"/>
                    <ComboBoxItem Content="100"  Tag="100"/>
                    <ComboBoxItem Content="250"  Tag="250"/>
                    <ComboBoxItem Content="500"  Tag="500"/>
                    <ComboBoxItem Content="1000" Tag="1000"/>
                    <ComboBoxItem Content="5000" Tag="5000"/>
                </ComboBox>
            </StackPanel>
        </Border>
            </Grid>   <!-- main content column -->
        </Grid>       <!-- BodyGrid -->
    </Grid>
</Page>
