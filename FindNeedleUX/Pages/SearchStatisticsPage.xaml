<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.SearchStatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="820" Spacing="12">
            <Grid>
                <TextBlock Text="Search statistics &amp; timing" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Button x:Name="RefreshButton" Content="Refresh" Click="Refresh_Click"/>
                    <Button x:Name="CopyButton" Content="Copy" Click="Copy_Click"/>
                </StackPanel>
            </Grid>
            <TextBlock Text="Throughput and where the time went for the most recent search — rows, storage backend, cache hit/miss, and the slowest phases (load, scan, index, viewer)."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <TextBlock x:Name="ReportText" FontFamily="Consolas" FontSize="12"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
