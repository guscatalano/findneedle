<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.SearchStatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:nrv="using:FindNeedleUX.Pages.NativeResultViewer"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="900" Spacing="16">

            <Grid>
                <StackPanel>
                    <TextBlock Text="Search statistics &amp; timing" FontSize="24" FontWeight="SemiBold"/>
                    <TextBlock x:Name="SubtitleText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Spacing="8">
                    <Button x:Name="OpenResolveLogButton" Content="Symbol resolution log" Visibility="Collapsed"
                            Click="OpenResolveLog_Click"
                            ToolTipService.ToolTip="What the ETL needed, where we searched, and what tracefmt found"/>
                    <Button x:Name="OpenRawOutputButton" Content="Raw tracefmt output" Visibility="Collapsed"
                            Click="OpenRawOutput_Click"
                            ToolTipService.ToolTip="Open the raw text tracefmt produced for the decoded ETL(s)"/>
                    <Button x:Name="RefreshButton" Content="Refresh" Click="Refresh_Click"/>
                    <Button x:Name="CopyButton" Content="Copy" Click="Copy_Click"/>
                </StackPanel>
            </Grid>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyState" Visibility="Collapsed" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="No search has run yet — run a search, then check back here."/>

            <!-- Stat cards -->
            <nrv:WrapPanelLite x:Name="Cards" HorizontalSpacing="12" VerticalSpacing="12"/>

            <!-- Where the time went -->
            <Border x:Name="PhasesCard" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Where the time went" FontWeight="SemiBold"/>
                    <StackPanel x:Name="PhaseBars" Spacing="6"/>
                </StackPanel>
            </Border>

            <!-- Notes / why -->
            <Border x:Name="NotesCard" Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Notes" FontWeight="SemiBold"/>
                    <StackPanel x:Name="Notes" Spacing="6"/>
                </StackPanel>
            </Border>

            <!-- Breakdown -->
            <Expander x:Name="BreakdownExpander" Header="Breakdown by component / provider / file"
                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <TreeView x:Name="BreakdownTree" AllowDrop="False" SelectionMode="None">
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <TreeViewItem Content="{Binding Content}" IsExpanded="True"/>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Expander>

            <!-- Raw report (text) -->
            <Expander Header="Raw report (text)" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="SummaryText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                    <TextBlock x:Name="PerfText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
