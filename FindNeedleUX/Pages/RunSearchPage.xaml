<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.RunSearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">
            <StackPanel Spacing="8">
                <TextBlock Text="🚀 Run Search" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Execute your search pipeline and view results" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Zero-source guard: shown instead of running over nothing. -->
            <InfoBar x:Name="NoSourcesBar" Severity="Warning" IsOpen="False" IsClosable="True"
                     Title="No sources to search"
                     Message="Add at least one source (a folder, file, or live log) before running.">
                <InfoBar.ActionButton>
                    <Button Content="Add source" Click="AddSource_Click"/>
                </InfoBar.ActionButton>
            </InfoBar>

            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Search Depth" FontWeight="SemiBold"/>
                    <StackPanel x:Name="DepthInputs" Orientation="Horizontal" Spacing="8">
                        <RadioButton Content="🔍 Shallow (fast)" GroupName="SearchDepth" Click="ShallowSearch_Click"/>
                        <RadioButton Content="🔍 Normal (default)" GroupName="SearchDepth" IsChecked="True" Click="NormalSearch_Click"/>
                        <RadioButton Content="🔍 Deep (thorough)" GroupName="SearchDepth" Click="DeepSearch_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="Actions" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="RunButton" Content="🚀 Run Search" Click="Button_Click" Height="48" FontSize="16"
                                Style="{ThemeResource AccentButtonStyle}"
                                AutomationProperties.Name="Run search"/>
                        <Button x:Name="CancelButton" Content="🛑 Cancel" Click="CancelButton_Click" Height="48" FontSize="16"
                                IsEnabled="False"
                                AutomationProperties.Name="Cancel search"/>
                    </StackPanel>

                    <ProgressBar x:Name="busybar" Width="300" Height="20" IsIndeterminate="True" ShowPaused="True" ShowError="False" Margin="0,8,0,0"
                                 AutomationProperties.Name="Search progress (indeterminate)"
                                 AutomationProperties.LiveSetting="Polite"/>
                    <ProgressBar x:Name="busybar2" Width="300" Height="20" IsIndeterminate="False" ShowPaused="True" ShowError="False"
                                 AutomationProperties.Name="Search progress"
                                 AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock x:Name="progresstext" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               AutomationProperties.LiveSetting="Polite"/>
                    
                    <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlForegroundAltHighBrush}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                        <StackPanel Spacing="4">
                            <TextBlock Text="Search Summary" FontWeight="SemiBold"/>
                            <TextBlock x:Name="summary" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
