<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.SearchLocationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:l="using:FindNeedleUX.ViewObjects"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <DataTemplate x:DataType="l:LocationListItem" x:Key="LocationTemplate">
            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlForegroundAltHighBrush}" CornerRadius="8" Padding="16" Margin="0,8,0,0">
                <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto" ColumnSpacing="12" RowSpacing="8">
                    <SymbolIcon Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Symbol="Folder" Foreground="{ThemeResource SystemAccentColorBrush}" VerticalAlignment="Top"
                                AutomationProperties.AccessibilityView="Raw"/>

                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{x:Bind Description}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                    <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Button Tag="{x:Bind Name}" Content="Edit" Width="70" Click="Button_Edit"
                                Visibility="{x:Bind EditVisibility}"
                                AutomationProperties.Name="{x:Bind Name, Mode=OneWay}" AutomationProperties.HelpText="Edit this location"/>
                        <Button Tag="{x:Bind Name}" Content="Remove" Width="80" Click="Button_Remove"
                                AutomationProperties.Name="{x:Bind Name, Mode=OneWay}" AutomationProperties.HelpText="Remove this location"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">
            <StackPanel Spacing="8">
                <TextBlock Text="📁 Search Locations" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Configure data sources for your search pipeline" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <Pivot>
                    <!-- New: pick a source to add -->
                    <PivotItem Header="New">
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <TextBlock Text="Local" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="➕ Add Folder" Click="Button_AddFolder" Width="120"
                                        AutomationProperties.Name="Add folder location"/>
                                <Button Content="➕ Add File" Click="Button_AddFile" Width="120"
                                        AutomationProperties.Name="Add file location"/>
                                <Button Content="📋 Add Live Event Log" Click="Button_AddEventLog" Width="180"
                                        ToolTipService.ToolTip="Read this machine's running Event Log channels (not a saved .evtx file — use Add File for those)"
                                        AutomationProperties.Name="Add live Windows Event Log location"/>
                            </StackPanel>

                            <TextBlock Text="Online sources" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="0,12,0,0"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="☁ Add Kusto" Click="Button_AddKusto" Width="120"
                                        AutomationProperties.Name="Add Kusto cluster location"/>
                                <Button Content="☁ Add ADO" Click="Button_AddAdo" Width="120"
                                        AutomationProperties.Name="Add Azure DevOps location"/>
                                <Button Content="☁ Add GitHub" Click="Button_AddGithub" Width="120"
                                        AutomationProperties.Name="Add GitHub issues location"/>
                            </StackPanel>

                            <StackPanel x:Name="StatusPanel" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0"
                                        Visibility="Collapsed" VerticalAlignment="Center">
                                <ProgressRing IsActive="True" Width="18" Height="18"/>
                                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </PivotItem>

                    <!-- Recent: one click to re-add a recently used file/folder -->
                    <PivotItem Header="Recent">
                        <StackPanel Spacing="8" Margin="0,8,0,0">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Recently used file/folder locations" VerticalAlignment="Center"
                                           FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Grid.Column="1" Text="Keep" VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <NumberBox Grid.Column="2" x:Name="RecentMaxBox" Minimum="1" Maximum="50" SpinButtonPlacementMode="Compact"
                                           Width="96" SmallChange="1" ValueChanged="RecentMax_ValueChanged"
                                           AutomationProperties.Name="How many recent locations to keep"/>
                                <Button Grid.Column="3" Content="Clear" Click="RecentClear_Click"/>
                            </Grid>
                            <StackPanel x:Name="RecentHost" Spacing="4"/>
                            <TextBlock x:Name="RecentEmpty" Text="No recent locations yet — add a folder or file and it'll show up here."
                                       FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed"/>
                        </StackPanel>
                    </PivotItem>
                </Pivot>
            </Border>

            <StackPanel Spacing="8">
                <TextBlock Text="Configured Locations" FontWeight="SemiBold"/>
                <ItemsRepeaterScrollHost>
                    <ScrollViewer>
                        <ItemsRepeater x:Name="VariedImageSizeRepeater"
                            ItemTemplate="{StaticResource LocationTemplate}">
                        </ItemsRepeater>
                    </ScrollViewer>
                </ItemsRepeaterScrollHost>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
