<Page
    x:Class="FindNeedleUX.Pages.ProcessorOutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="ToggleListButton" Click="ToggleList_Click"
                    VerticalAlignment="Top" Padding="8" Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Show/hide the list">
                <FontIcon x:Name="ToggleListIcon" Glyph="&#xE700;" FontSize="16" />
            </Button>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="Processor Output" FontSize="26" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryText" FontSize="13" Foreground="Gray" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Grid.Column="2" VerticalAlignment="Top" HorizontalAlignment="Right" Spacing="4" MaxWidth="280">
                <Button x:Name="GenerateButton" Click="Generate_Click" HorizontalAlignment="Right"
                        Style="{StaticResource AccentButtonStyle}"
                        ToolTipService.ToolTip="Run the enabled output rules (e.g. UML diagrams) over the current results, limited to the results view's time range">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon x:Name="GenerateIcon" Glyph="&#xE768;" FontSize="14" />
                        <TextBlock x:Name="GenerateLabel" Text="Generate" />
                    </StackPanel>
                </Button>
                <!-- Makes it obvious the generation respects the view's time filter. -->
                <Border x:Name="TimeRangeNote" Visibility="Collapsed" HorizontalAlignment="Right"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE823;" FontSize="12" VerticalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock x:Name="TimeRangeText" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="NoTimeRangeNote" Visibility="Collapsed" HorizontalAlignment="Right"
                           FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           Text="Generates over all results."
                           TextWrapping="Wrap" TextAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- Master / detail -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListColumn" Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ListBorder" Grid.Column="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView x:Name="OutputList"
                          SelectionMode="Single"
                          SelectionChanged="OutputList_SelectionChanged"
                          Padding="4" />
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid x:Name="DetailHost" Padding="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </Border>
        </Grid>

        <!-- Fullscreen diagram overlay: covers the whole page when the user maximizes a diagram. -->
        <Grid x:Name="FullscreenOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed"
              Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" ColumnSpacing="8" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FullscreenTitle" Grid.Column="0" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="1" Click="ExitFullscreen_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE73F;" FontSize="14" />
                        <TextBlock Text="Exit fullscreen (Esc)" />
                    </StackPanel>
                </Button>
            </Grid>
            <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid x:Name="FullscreenHost" />
            </Border>
        </Grid>

        <!-- Generating overlay: themed loader gif while an output rule runs. -->
        <Border x:Name="GeneratingOverlay" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed"
                Background="#90000000" AutomationProperties.LiveSetting="Polite">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <Image x:Name="GeneratingGif" Width="160" Height="160" Visibility="Collapsed"/>
                <ProgressRing x:Name="GeneratingRing" Width="48" Height="48" IsActive="True"/>
                <TextBlock x:Name="GeneratingText" Text="Generating diagram…" Foreground="White"
                           FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
