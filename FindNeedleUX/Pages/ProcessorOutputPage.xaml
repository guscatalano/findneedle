<Page
    x:Class="FindNeedleUX.Pages.ProcessorOutputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid Margin="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="ToggleListButton" Click="ToggleList_Click"
                    VerticalAlignment="Top" Padding="8" Background="Transparent" BorderThickness="0"
                    ToolTipService.ToolTip="Show/hide the list">
                <FontIcon x:Name="ToggleListIcon" Glyph="&#xE700;" FontSize="16" />
            </Button>
            <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="Processor Output" FontSize="26" FontWeight="SemiBold" />
                <TextBlock x:Name="SummaryText" FontSize="13" Foreground="Gray" TextWrapping="Wrap" />
            </StackPanel>
        </Grid>

        <!-- Master / detail -->
        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ListColumn" Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ListBorder" Grid.Column="0"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <ListView x:Name="OutputList"
                          SelectionMode="Single"
                          SelectionChanged="OutputList_SelectionChanged"
                          Padding="4" />
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <Grid x:Name="DetailHost" Padding="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
            </Border>
        </Grid>
    </Grid>
</Page>
