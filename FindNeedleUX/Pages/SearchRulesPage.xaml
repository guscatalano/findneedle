<Page
    x:Class="FindNeedleUX.Pages.SearchRulesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewobjects="using:FindNeedleUX.ViewObjects"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">
            <!-- Title -->
            <StackPanel Spacing="8">
                <TextBlock Text="⚙️ RuleDSL Configuration" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="Manage rule files and pipeline sections" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Rule Files Section -->
            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="12">
                    <TextBlock Text="📁 Rule Files" FontWeight="SemiBold"/>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="BrowseButton" Content="📂 Browse..." Click="BrowseButton_Click"
                                AutomationProperties.Name="Browse for rule file"/>
                        <Button x:Name="RemoveButton" Content="🗑️ Remove Selected" Click="RemoveButton_Click" IsEnabled="False"
                                AutomationProperties.Name="Remove selected rule file"/>
                        <TextBox x:Name="TestFilePathInput" Width="200" Height="32" Header="Test file path" PlaceholderText="Enter file path" KeyDown="TestFilePathInput_KeyDown"
                                 AutomationProperties.Name="Test file path"/>
                        <Button x:Name="TestLoadButton" Content="🚀 Load" Click="TestLoadButton_Click" Height="32"
                                AutomationProperties.Name="Load test file"/>
                    </StackPanel>

                    <ListView x:Name="RuleFilesListBox" ItemsSource="{x:Bind RuleFiles, Mode=OneWay}" Height="150" SelectionChanged="RuleFilesListBox_SelectionChanged"
                              AutomationProperties.Name="Loaded rule files">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewobjects:RuleFileItem">
                                <Grid ColumnSpacing="8" Padding="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind FilePath}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="📄 Open" Click="OpenRuleFile_Click" Tag="{x:Bind FilePath}"
                                            VerticalAlignment="Center" FontSize="12"
                                            ToolTipService.ToolTip="Open this rules.json in the default editor"
                                            AutomationProperties.Name="Open rule file"/>

                                    <SymbolIcon Grid.Column="2" Symbol="Accept" Foreground="{ThemeResource SystemFillColorSuccessBrush}" Visibility="{x:Bind IsValid}"
                                                AutomationProperties.Name="Valid"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyRuleFilesText" Visibility="Collapsed" FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="No rule files yet. Rules are optional — you can search without them. Use Browse… to add a .rules.json (rules auto-tag, filter, scope, and enrich your results)."/>
                </StackPanel>
            </Border>

            <!-- Rule Sections Section -->
            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" CornerRadius="8" Padding="16" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Left">
                        <TextBlock Text="📋 Pipeline Sections" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PurposeFilterCombo" SelectionChanged="PurposeFilterCombo_SelectionChanged" Width="120"
                                  Header="Filter by purpose" AutomationProperties.Name="Filter sections by purpose">
                            <ComboBoxItem IsSelected="True" Tag="All">All Purposes</ComboBoxItem>
                            <ComboBoxItem Tag="scope">Scope</ComboBoxItem>
                            <ComboBoxItem Tag="filter">Filter</ComboBoxItem>
                            <ComboBoxItem Tag="enrichment">Enrichment</ComboBoxItem>
                            <ComboBoxItem Tag="uml">UML</ComboBoxItem>
                            <ComboBoxItem Tag="output">Output</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <ListView x:Name="RuleSectionsListView" ItemsSource="{x:Bind RuleSections, Mode=OneWay}">
                        <ListView.Header>
                            <Grid ColumnSpacing="12" Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="150"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Name / Description" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2" Text="Rules" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="Source" FontWeight="SemiBold"/>
                            </Grid>
                        </ListView.Header>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewobjects:RuleSectionItem">
                                <Grid ColumnSpacing="12" Padding="12" BorderBrush="{ThemeResource SystemControlBackgroundAltHighBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="150"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{x:Bind Description}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="{x:Bind PurposeDisplay}" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{x:Bind RuleCount}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind SourceFileName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
