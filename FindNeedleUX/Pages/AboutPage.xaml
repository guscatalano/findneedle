<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="640" Spacing="16">
            <TextBlock Text="About FindNeedle" FontSize="22" FontWeight="SemiBold"/>
            <TextBlock Text="A Windows log-search utility built on a plugin + declarative-rule pipeline."
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

            <!-- Version -->
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <StackPanel x:Name="VersionPanel" Spacing="4"/>
            </Border>

            <!-- Performance report -->
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Performance" FontWeight="SemiBold"/>
                    <TextBlock Text="Export a human-readable report: this machine's spec, the most recent search's pipeline timings, any slow UX interactions, and the cache/disk footprint."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    <Button x:Name="ExportPerfReportButton" Content="Export performance report"
                            Click="ExportPerfReport_Click"/>
                    <TextBlock x:Name="PerfReportStatus" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" IsTextSelectionEnabled="True" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- Links -->
            <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock Text="Links" FontWeight="SemiBold"/>
                    <TextBlock>
                        <Run Text="Store page: "/>
                        <Hyperlink NavigateUri="https://www.microsoft.com/store/productId/9NWLTBV4NRDL?ocid=libraryshare" Click="StoreLink_Click">Microsoft Store</Hyperlink>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Open in Store app: "/>
                        <Hyperlink NavigateUri="ms-windows-store://pdp/?productid=9NWLTBV4NRDL" Click="MsStoreLink_Click">ms-windows-store://…</Hyperlink>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="GitHub releases: "/>
                        <Hyperlink NavigateUri="https://github.com/guscatalano/findneedle/releases" Click="GithubReleasesLink_Click">github.com/guscatalano/findneedle/releases</Hyperlink>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Source: "/>
                        <Hyperlink NavigateUri="https://github.com/guscatalano/findneedle" Click="GithubLink_Click">github.com/guscatalano/findneedle</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
