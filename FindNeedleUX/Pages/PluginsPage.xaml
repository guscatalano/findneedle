<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="FindNeedleUX.Pages.PluginsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="16" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel>
                <TextBlock Text="Plugins &amp; modules" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="Loaded plugin DLLs and the plugins they provide. ✓ loaded · ✗ failed to load · ⚠ invalid"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
            </StackPanel>
            <Button x:Name="ReloadButton" Content="Reload all plugins" Click="ReloadAllPlugins_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top"/>
        </Grid>

        <ProgressBar Grid.Row="1" x:Name="InitProgressBar" IsIndeterminate="True" Visibility="Collapsed" Height="4"/>

        <!-- Body: master (tree) + detail -->
        <Grid Grid.Row="2" x:Name="BodyGrid" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Master: modules → plugins tree -->
            <Border Grid.Column="0"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="4">
                <TreeView x:Name="PluginTree" SelectionMode="Single" ItemInvoked="PluginTree_ItemInvoked">
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <TreeViewItem IsExpanded="True">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Content.Glyph}" Foreground="{Binding Content.GlyphBrush}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Content.Text}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Border>

            <!-- Detail + config -->
            <ScrollViewer Grid.Column="1">
                <StackPanel Spacing="12">

                    <!-- Selected plugin -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock x:Name="DetailTitle" Text="Select a plugin" FontWeight="SemiBold" FontSize="16"/>
                            <TextBlock Text="Description" FontWeight="SemiBold" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="PluginDescriptionTextBlock" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                            <TextBlock Text="Class" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="PluginClassNameTextBlock" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True"/>
                            <TextBlock Text="Implemented interfaces" FontWeight="SemiBold" FontSize="12" Margin="0,4,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="PluginInterfacesTextBlock" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <!-- Owning module -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="6">
                            <TextBlock Text="Module" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PluginModuleTextBlock" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True"/>
                            <TextBlock x:Name="ModuleLoadedStatusTextBlock" TextWrapping="Wrap" FontSize="12"/>
                            <TextBlock x:Name="ModuleLoadExceptionTextBlock" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                            <TextBlock x:Name="ModuleLoadExceptionStringTextBlock" TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Plugin configuration (was the second tab) -->
                    <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                              Header="Plugin configuration (DLLs)">
                        <StackPanel Spacing="8">
                            <TextBlock Text="DLLs FindNeedle loads at startup. Edit, enable/disable, or add new plugin assemblies, then Save."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ListView x:Name="PluginConfigListView" ItemsSource="{x:Bind PluginConfigEntries, Mode=TwoWay}"
                                      SelectionMode="Single" SelectedItem="{x:Bind SelectedPluginConfigEntry, Mode=TwoWay}">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:PluginConfigEntryViewModel">
                                        <StackPanel Orientation="Horizontal" Spacing="4" Padding="0,2,0,2">
                                            <TextBox Text="{x:Bind Name, Mode=TwoWay}" Width="160" PlaceholderText="Name"/>
                                            <TextBox Text="{x:Bind Path, Mode=TwoWay}" Width="280" PlaceholderText="Path to .dll"/>
                                            <Button Content="…" Width="32" Click="PickPluginFile_Click" Tag="{x:Bind}"/>
                                            <CheckBox IsChecked="{x:Bind Enabled, Mode=TwoWay}" Content="Enabled" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Add" Click="AddPluginConfigEntry_Click"/>
                                <Button Content="Remove" Click="RemovePluginConfigEntry_Click"/>
                                <Button Content="Save" Click="SavePluginConfig_Click" Style="{ThemeResource AccentButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
