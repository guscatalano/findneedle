<Page
    x:Class="FindNeedleUX.Pages.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="24">
            <!-- Hero: animated themed loader + wordmark -->
            <Border CornerRadius="12" Padding="24">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.12"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal" Spacing="20">
                    <Border Width="96" Height="96" CornerRadius="12" VerticalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                        <Image x:Name="HeroGif" Width="96" Height="96" Stretch="UniformToFill"
                               AutomationProperties.AccessibilityView="Raw"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="FindNeedle" FontSize="36" FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Advanced Log Search &amp; Analysis" FontSize="16"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Search, filter, and diagram logs across folders, ETW, and event logs."
                                   FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" MaxWidth="420"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Quick Actions -->
            <TextBlock Text="Quick Actions" FontWeight="SemiBold" FontSize="18"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="📁 Open Log File" Click="OpenLogFileButton_Click" Height="80" HorizontalAlignment="Left"
                        AutomationProperties.Name="Open log file">
                    <Button.Background>
                        <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.1"/>
                    </Button.Background>
                </Button>
                <Button Content="📂 Open Folder" Click="OpenFolderButton_Click" Height="80" HorizontalAlignment="Left"
                        AutomationProperties.Name="Open folder of logs">
                    <Button.Background>
                        <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.1"/>
                    </Button.Background>
                </Button>
                <Button Content="📝 Open Log with Rules" Click="OpenLogWithRulesButton_Click" Height="80" HorizontalAlignment="Left"
                        AutomationProperties.Name="Open log with rules">
                    <Button.Background>
                        <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.1"/>
                    </Button.Background>
                </Button>
            </StackPanel>

            <!-- Features -->
            <TextBlock Text="Key Features" FontWeight="SemiBold" FontSize="18"/>
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Folder" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                    <TextBlock Text="Plugin-based data sources (folders, files, event logs, ETW)" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Filter" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                    <TextBlock Text="RuleDSL for filtering, enrichment, and UML generation" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="List" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                    <TextBlock Text="Multiple result viewers (Web, Community, Native)" TextWrapping="Wrap"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <SymbolIcon Symbol="Pictures" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                    <TextBlock Text="PlantUML/Mermaid integration for diagram generation" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Documentation Link -->
            <Border BorderThickness="1" BorderBrush="{ThemeResource SystemControlBackgroundAccentBrush}" Padding="16" CornerRadius="8" Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
                <StackPanel Spacing="8">
                    <TextBlock Text="📖 Getting started" FontWeight="SemiBold"/>
                    <TextBlock Text="Pick a quick action above, or use the Configure menu to set up locations, filters, and RuleDSL files for a custom search pipeline." TextWrapping="Wrap"/>
                    <HyperlinkButton Content="View Documentation" NavigateUri="https://github.com/guscatalano/findneedle"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
