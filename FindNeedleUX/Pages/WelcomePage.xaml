<Page
    x:Class="FindNeedleUX.Pages.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">
            <!-- Hero: animated themed loader + wordmark -->
            <Border CornerRadius="12" Padding="20">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.12"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal" Spacing="18">
                    <Border Width="84" Height="84" CornerRadius="12" VerticalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                        <Image x:Name="HeroGif" Width="84" Height="84" Stretch="UniformToFill"
                               AutomationProperties.AccessibilityView="Raw"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="FindNeedle" FontSize="32" FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Advanced Log Search &amp; Analysis" FontSize="15"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Search, filter, and diagram logs across folders, ETW, and event logs."
                                   FontSize="13" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap" MaxWidth="440"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Getting started + key features: prominent under the hero, permanently dismissible
                 (× sets ResultsViewerSettings.ShowWelcomeIntro=false; a Preferences toggle restores it). -->
            <InfoBar x:Name="IntroBanner" IsOpen="True" IsClosable="True" Severity="Informational"
                     CloseButtonClick="IntroBanner_CloseButtonClick"
                     Title="Getting started">
                <InfoBar.Content>
                    <!-- Lead with one plain "start here" line; everything else (pipeline steps, features,
                         jargon) is tucked behind a collapsed expander so the banner stays short and the
                         Quick Actions below are the obvious next step. -->
                    <StackPanel Spacing="8" Margin="0,4,0,12">
                        <TextBlock TextWrapping="Wrap"
                                   Text="Pick a Quick Action below to open a log — results appear right away."/>
                        <Expander HorizontalAlignment="Left" Header="Building a custom pipeline? What else can it do?">
                            <StackPanel Spacing="8" Margin="0,4,0,0" MaxWidth="520">
                                <TextBlock TextWrapping="Wrap"
                                           Text="For a multi-source search, use Configure ▸ Sources / Connections / Rules to build a pipeline, then run it from Run &amp; Results (or the Run → View Results button in the status bar)."/>
                                <TextBlock Text="What it does" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Folder" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                    <TextBlock Text="Sources: folders, files, event logs, ETW, online sources" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Filter" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                    <TextBlock Text="RuleDSL filtering, enrichment, and UML generation" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="List" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                    <TextBlock Text="Fast viewer with paging, tagging, and column controls" TextWrapping="Wrap"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Pictures" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                    <TextBlock Text="PlantUML / Mermaid diagrams from logs" TextWrapping="Wrap"/>
                                </StackPanel>
                                <HyperlinkButton Content="View documentation" NavigateUri="https://github.com/guscatalano/findneedle" Padding="0"/>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- Quick Actions (customizable) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Quick Actions" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="EditQuickActionsButton" Click="EditQuickActions_Click"
                        Background="Transparent" BorderThickness="0" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon x:Name="EditQuickActionsIcon" Symbol="Edit"/>
                        <TextBlock x:Name="EditQuickActionsLabel" Text="Edit"/>
                    </StackPanel>
                </Button>
            </Grid>
            <local:SimpleWrapPanel x:Name="QuickActionsHost" HorizontalSpacing="12" VerticalSpacing="12"/>

        </StackPanel>
    </ScrollViewer>
</Page>
