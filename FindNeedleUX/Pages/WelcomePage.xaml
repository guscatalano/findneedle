<Page
    x:Class="FindNeedleUX.Pages.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FindNeedleUX.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24,16,24,24">
        <StackPanel Spacing="16">
            <!-- Hero: animated themed loader + wordmark (compact, so the quick actions sit higher) -->
            <Border CornerRadius="10" Padding="14">
                <Border.Background>
                    <SolidColorBrush Color="{ThemeResource SystemAccentColor}" Opacity="0.12"/>
                </Border.Background>
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <Border Width="56" Height="56" CornerRadius="10" VerticalAlignment="Center"
                            Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                        <Image x:Name="HeroGif" Width="56" Height="56" Stretch="UniformToFill"
                               AutomationProperties.AccessibilityView="Raw"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="FindNeedle" FontSize="22" FontWeight="Bold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Advanced Log Search &amp; Analysis" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Getting started + key features: prominent under the hero, permanently dismissible
                 (× sets ResultsViewerSettings.ShowWelcomeIntro=false; a Preferences toggle restores it). -->
            <InfoBar x:Name="IntroBanner" IsOpen="True" IsClosable="True" Severity="Informational"
                     CloseButtonClick="IntroBanner_CloseButtonClick"
                     Title="New here?">
                <InfoBar.Content>
                    <StackPanel Spacing="10" Margin="0,4,0,12">
                        <TextBlock TextWrapping="Wrap"
                                   Text="Pick a Quick Action below to open logs, or use Configure ▸ Locations / Connections / Rules to build a custom search pipeline. Then run it from Run &amp; Results (or the Run → View Results button in the status bar)."/>
                        <TextBlock Text="Key features" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Folder" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                <TextBlock Text="Plugin-based data sources (folders, files, event logs, ETW, online sources)" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Filter" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                <TextBlock Text="RuleDSL for filtering, enrichment, and UML generation" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="List" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                <TextBlock Text="Fast result viewer with paging, tagging, and column controls" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Pictures" Foreground="{ThemeResource SystemAccentColorBrush}" AutomationProperties.AccessibilityView="Raw"/>
                                <TextBlock Text="PlantUML / Mermaid diagram generation from logs" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                        <HyperlinkButton Content="View documentation" NavigateUri="https://github.com/guscatalano/findneedle" Padding="0"/>
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>

            <!-- Quick Actions (customizable) -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Quick Actions" FontWeight="SemiBold" FontSize="18" VerticalAlignment="Center"/>
                <Button Grid.Column="1" x:Name="EditQuickActionsButton" Click="EditQuickActions_Click"
                        Background="Transparent" BorderThickness="0" Padding="8,4">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon x:Name="EditQuickActionsIcon" Symbol="Edit"/>
                        <TextBlock x:Name="EditQuickActionsLabel" Text="Edit"/>
                    </StackPanel>
                </Button>
            </Grid>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel x:Name="QuickActionsHost" Orientation="Horizontal" Spacing="12"/>
            </ScrollViewer>

        </StackPanel>
    </ScrollViewer>
</Page>
