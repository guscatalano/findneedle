<Page
    x:Class="FindNeedleUX.Pages.ResultsViewerSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:nrv="using:FindNeedleUX.Pages.NativeResultViewer"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <nrv:HexToBrushConverter x:Key="HexToBrush"/>
    </Page.Resources>

    <NavigationView x:Name="SettingsNav" PaneDisplayMode="Left"
                    IsBackButtonVisible="Collapsed" IsSettingsVisible="False"
                    PaneTitle="Viewer settings"
                    SelectionChanged="SettingsNav_SelectionChanged">
        <NavigationView.AutoSuggestBox>
            <AutoSuggestBox x:Name="SettingsSearchBox" QueryIcon="Find"
                            AutomationProperties.AutomationId="SettingsSearchBox"
                            PlaceholderText="Search settings…"
                            TextChanged="SettingsSearch_TextChanged"
                            SuggestionChosen="SettingsSearch_SuggestionChosen"
                            QuerySubmitted="SettingsSearch_QuerySubmitted"/>
        </NavigationView.AutoSuggestBox>
        <NavigationView.MenuItems>
            <NavigationViewItem Content="All settings" Tag="all">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE8A9;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItemSeparator/>
            <NavigationViewItem Content="Appearance" Tag="appearance" IsSelected="True">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE790;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="General" Tag="general">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE713;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Search" Tag="search">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE721;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Columns" Tag="columns">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE71D;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Decoding" Tag="decoding">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Integrations" Tag="integrations">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE968;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Support" Tag="logs">
                <NavigationViewItem.Icon><FontIcon Glyph="&#xE7C3;"/></NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <ScrollViewer Padding="24">
            <StackPanel MaxWidth="640" Spacing="16">

                <TextBlock x:Name="CategoryTitle" Text="Appearance" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Text="These preferences are saved per-user and apply to the native results viewer."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>

                <!-- ============================ APPEARANCE ============================ -->
                <StackPanel x:Name="PanelAppearance" Spacing="16">

                    <!-- Loading animation -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Loading animation" FontWeight="SemiBold"/>
                            <TextBlock Text="What the full-window loading overlay shows during searches and file opens."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Category" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="LoaderCategoryCombo" Width="170"
                                              SelectionChanged="LoaderCategoryCombo_SelectionChanged"
                                              AutomationProperties.Name="Loading animation category"/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Style" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="LoaderItemCombo" Width="220"
                                              SelectionChanged="LoaderItemCombo_SelectionChanged"
                                              AutomationProperties.Name="Loading animation style"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Robot-specific options -->
                            <StackPanel x:Name="RobotOptionsPanel" Spacing="8" Margin="0,4,0,0">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Shape" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <ComboBox x:Name="RobotWidthCombo" Width="160"
                                              SelectionChanged="RobotWidthCombo_SelectionChanged"
                                              AutomationProperties.Name="Robot shape">
                                        <ComboBoxItem Content="Wide"   Tag="Wide"/>
                                        <ComboBoxItem Content="Square" Tag="Narrow"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <!-- Preview (both modes) -->
                            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                <StackPanel Spacing="8" HorizontalAlignment="Center" MinHeight="120">
                                    <!-- Spinner preview -->
                                    <ProgressRing x:Name="SpinnerPreviewRing" Width="56" Height="56"
                                                  IsActive="False" Visibility="Collapsed"
                                                  VerticalAlignment="Center"/>
                                    <!-- Progress-bar preview -->
                                    <ProgressBar x:Name="BarPreview" Width="240" IsIndeterminate="False"
                                                 Visibility="Collapsed" VerticalAlignment="Center"/>
                                    <!-- Robot preview -->
                                    <StackPanel x:Name="RobotPreviewBox" Spacing="8" HorizontalAlignment="Center">
                                        <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                                CornerRadius="12" Padding="12" HorizontalAlignment="Center">
                                            <Image x:Name="RobotPreviewImage" MaxWidth="320" MaxHeight="200" Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock x:Name="RobotPreviewStepText" HorizontalAlignment="Center" FontSize="12"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <Button x:Name="RobotPrevButton" Content="← Prev" Click="RobotPreviewPrev_Click"/>
                                            <Button x:Name="RobotNextButton" Content="Next →" Click="RobotPreviewNext_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Time format -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Time format" FontWeight="SemiBold"/>
                            <!-- Items are populated in code (PopulateTimeFormatCombo) so each row shows a
                                 live example rendered from its own format string — always consistent, no dupes. -->
                            <ComboBox x:Name="TimeFormatCombo" Width="360"
                                      SelectionChanged="TimeFormatCombo_SelectionChanged"
                                      AutomationProperties.Name="Time format"/>
                            <TextBlock x:Name="TimeFormatPreview"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       FontFamily="Consolas" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Color theme -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Color theme" FontWeight="SemiBold"/>
                            <TextBlock Text="A preset that fills in level row backgrounds. Picking a theme overwrites individual color overrides below."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="ThemeCombo" Width="220"
                                      SelectionChanged="ThemeCombo_SelectionChanged"
                                      AutomationProperties.Name="Color theme">
                                <ComboBoxItem Content="Subtle (default)" Tag="Subtle"/>
                                <ComboBoxItem Content="Vivid"            Tag="Vivid"/>
                                <ComboBoxItem Content="Classic (red/yellow)" Tag="Classic"/>
                                <ComboBoxItem Content="Bold"             Tag="Bold"/>
                                <ComboBoxItem Content="Ocean"            Tag="Ocean"/>
                                <ComboBoxItem Content="Forest"           Tag="Forest"/>
                                <ComboBoxItem Content="Sunset"           Tag="Sunset"/>
                                <ComboBoxItem Content="Grayscale"        Tag="Grayscale"/>
                                <ComboBoxItem Content="None"             Tag="None"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Per-level colors (kept next to Color theme — a theme is just a preset for these) -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <Grid>
                                <TextBlock Text="Level colors" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="Reset all to theme defaults" Click="ResetAllColors_Click"
                                        HorizontalAlignment="Right" FontSize="12"/>
                            </Grid>
                            <TextBlock Text="The colors used to tint result rows by level. This is the only place to change them — click a swatch to pick a custom color; Reset reverts that level to the current theme."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ItemsControl x:Name="LevelEditor">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="nrv:LevelEntry">
                                        <Grid Padding="0,6,0,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Level}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            <Button Grid.Column="1" Click="PickColor_Click" Tag="{x:Bind Level}"
                                                    Padding="2" MinHeight="0" MinWidth="0"
                                                    ToolTipService.ToolTip="Pick custom color">
                                                <Border Width="32" Height="20" CornerRadius="3" BorderThickness="1"
                                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                        Background="{x:Bind HexColor, Mode=OneWay, Converter={StaticResource HexToBrush}}"/>
                                            </Button>
                                            <TextBlock Grid.Column="2" Text="{x:Bind HexColor, Mode=OneWay}"
                                                       VerticalAlignment="Center" FontFamily="Consolas" FontSize="12"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                            <Button Grid.Column="4" Content="Reset" Click="ResetColor_Click" Tag="{x:Bind Level}"
                                                    FontSize="12"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Title bar color -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Title bar" FontWeight="SemiBold"/>
                            <TextBlock Text="Color of the window's title bar. Takes effect on Windows 11."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="TitleBarModeCombo" Width="220"
                                      SelectionChanged="TitleBarModeCombo_SelectionChanged"
                                      AutomationProperties.Name="Title bar color mode">
                                <ComboBoxItem Content="System default" Tag="System"/>
                                <ComboBoxItem Content="Accent color"   Tag="Accent"/>
                                <ComboBoxItem Content="Custom…"         Tag="Custom"/>
                            </ComboBox>
                            <StackPanel x:Name="TitleBarCustomPanel" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center" Visibility="Collapsed">
                                <Button Click="TitleBarColor_Click" Padding="2" MinHeight="0" MinWidth="0"
                                        ToolTipService.ToolTip="Pick a custom title bar color">
                                    <Border x:Name="TitleBarSwatch" Width="40" Height="22" CornerRadius="3"
                                            BorderThickness="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                </Button>
                                <TextBlock x:Name="TitleBarHexText" VerticalAlignment="Center"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Scrollbar -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Scrollbar" FontWeight="SemiBold"/>
                            <TextBlock Text="How thick the result grid's scrollbar is. Larger sizes are easier to see and grab."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="ScrollBarSizeCombo" Width="220"
                                      SelectionChanged="ScrollBarSizeCombo_SelectionChanged"
                                      AutomationProperties.Name="Scrollbar size">
                                <ComboBoxItem Content="Default (thin)" Tag="12"/>
                                <ComboBoxItem Content="Medium"        Tag="18"/>
                                <ComboBoxItem Content="Large"         Tag="24"/>
                                <ComboBoxItem Content="Extra large"   Tag="32"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Row text size -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Row text size" FontWeight="SemiBold"/>
                            <TextBlock Text="Font size of the result grid's rows. Smaller fits more rows on screen; larger is easier to read."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="RowFontSizeCombo" Width="220"
                                      SelectionChanged="RowFontSizeCombo_SelectionChanged"
                                      AutomationProperties.Name="Row text size">
                                <ComboBoxItem Content="Compact (9)"  Tag="9"/>
                                <ComboBoxItem Content="Small (11)"   Tag="11"/>
                                <ComboBoxItem Content="Default (12)" Tag="12"/>
                                <ComboBoxItem Content="Medium (14)"  Tag="14"/>
                                <ComboBoxItem Content="Large (16)"   Tag="16"/>
                                <ComboBoxItem Content="Extra large (20)" Tag="20"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Row height (density) -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Row height" FontWeight="SemiBold"/>
                            <TextBlock Text="How tall each row is relative to its text. Tighter fits more rows on screen; roomier is easier to scan."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="RowHeightRatioCombo" Width="220"
                                      SelectionChanged="RowHeightRatioCombo_SelectionChanged"
                                      AutomationProperties.Name="Row height">
                                <ComboBoxItem Content="Tight"            Tag="1.4"/>
                                <ComboBoxItem Content="Comfortable (default)" Tag="1.9"/>
                                <ComboBoxItem Content="Roomy"            Tag="2.4"/>
                                <ComboBoxItem Content="Spacious"         Tag="3"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Row tags -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Row tags" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ColorTaggedRowsCheck" Content="Also color the whole row with the tag color"
                                      Checked="ColorTaggedRowsCheck_Changed" Unchecked="ColorTaggedRowsCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Tagged rows always show a colored tag glyph on the left. Turn this on to tint the whole row too."/>
                        </StackPanel>
                    </Border>

                    <!-- Paging -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Paging" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ScrollToTopOnPageChangeCheck" Content="Scroll to the top when changing pages"
                                      Checked="ScrollToTopOnPageChangeCheck_Changed" Unchecked="ScrollToTopOnPageChangeCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="When you move to another page (Next / Prev / First / Last / change page size), jump to the top of the new page. Turn off to keep your scroll position."/>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ============================ GENERAL ============================ -->
                <StackPanel x:Name="PanelGeneral" Spacing="16" Visibility="Collapsed">

                    <!-- Default sort -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Default sort" FontWeight="SemiBold"/>
                            <TextBlock Text="How rows are sorted when a log first opens. &quot;Load order&quot; keeps the exact order rows were read from the source (not necessarily by time). You can always click a column header to re-sort."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="DefaultSortCombo" Width="320"
                                      SelectionChanged="DefaultSortCombo_SelectionChanged"
                                      AutomationProperties.Name="Default sort">
                                <ComboBoxItem Content="Load order — as read (default)" Tag="LoadOrder"/>
                                <ComboBoxItem Content="Time — oldest first"           Tag="TimeAscending"/>
                                <ComboBoxItem Content="Time — newest first"           Tag="TimeDescending"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- "Show known" filter dropdown mode (per field) -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Known-value filter dropdowns" FontWeight="SemiBold"/>
                            <TextBlock Text="When the result viewer's &quot;Known ▾&quot; filter is on, choose whether each column's dropdown lets you pick one value or several (matched as any-of)."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <Grid ColumnSpacing="12" RowSpacing="6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Provider" VerticalAlignment="Center" FontSize="13"/>
                                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="KnownModeProviderCombo" Width="180"
                                          SelectionChanged="KnownModeProviderCombo_SelectionChanged" AutomationProperties.Name="Provider known-filter mode">
                                    <ComboBoxItem Content="Single select" Tag="Single"/>
                                    <ComboBoxItem Content="Multi select"  Tag="Multi"/>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TaskName" VerticalAlignment="Center" FontSize="13"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="KnownModeTaskNameCombo" Width="180"
                                          SelectionChanged="KnownModeTaskNameCombo_SelectionChanged" AutomationProperties.Name="TaskName known-filter mode">
                                    <ComboBoxItem Content="Single select" Tag="Single"/>
                                    <ComboBoxItem Content="Multi select"  Tag="Multi"/>
                                </ComboBox>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Source" VerticalAlignment="Center" FontSize="13"/>
                                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="KnownModeSourceCombo" Width="180"
                                          SelectionChanged="KnownModeSourceCombo_SelectionChanged" AutomationProperties.Name="Source known-filter mode">
                                    <ComboBoxItem Content="Single select" Tag="Single"/>
                                    <ComboBoxItem Content="Multi select"  Tag="Multi"/>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Welcome page -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Welcome page" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ShowWelcomeIntroCheck" Content="Show the &quot;New here?&quot; getting-started banner"
                                      Checked="ShowWelcomeIntroCheck_Changed" Unchecked="ShowWelcomeIntroCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="The intro + key-features banner at the top of the welcome page. Dismissing it there also unchecks this."/>
                        </StackPanel>
                    </Border>

                    <!-- Status bar -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Status bar" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ShowStatusBarCheck" Content="Show the status bar"
                                      Checked="ShowStatusBarCheck_Changed" Unchecked="ShowStatusBarCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="The bar at the top with Sources / Rules / Last run / Run → View Results. Closing it with the × turns this off."/>
                        </StackPanel>
                    </Border>

                    <!-- Drag and drop behavior -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Drag and drop" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When you drag a file or folder onto the viewer and a workspace is already loaded."/>
                            <ComboBox x:Name="DragDropModeCombo" Width="320"
                                      SelectionChanged="DragDropModeCombo_SelectionChanged"
                                      AutomationProperties.Name="Drag and drop behavior">
                                <ComboBoxItem Content="Ask every time (default)"   Tag="Prompt"/>
                                <ComboBoxItem Content="Clear workspace and open"   Tag="ClearAndAdd"/>
                                <ComboBoxItem Content="Add to existing workspace"  Tag="AddToExisting"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ============================ SEARCH ============================ -->
                <StackPanel x:Name="PanelSearch" Spacing="16" Visibility="Collapsed">

                    <!-- Progressive loading -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Progressive loading" FontWeight="SemiBold"/>
                            <CheckBox x:Name="StreamWhileLoadingCheck"
                                      Content="Open logs as they load"
                                      Checked="StreamWhileLoadingCheck_Changed" Unchecked="StreamWhileLoadingCheck_Changed"/>
                            <TextBlock TextWrapping="Wrap" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Shows the viewer as soon as the first page is ready and keeps filling rows in the background (with a banner and a live, rising count). Turn off to wait for the full scan before the viewer opens."/>
                        </StackPanel>
                    </Border>

                    <!-- Cache reuse -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Cache search results" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When you reopen a file that hasn't changed (same size + last-modified time), reuse the previously scanned results and skip the search. Reopens go from several seconds to instant."/>
                            <ComboBox x:Name="CacheReuseModeCombo" Width="320"
                                      SelectionChanged="CacheReuseModeCombo_SelectionChanged"
                                      AutomationProperties.Name="Cache reuse mode">
                                <ComboBoxItem Content="Ask me each time (default)"        Tag="Prompt"/>
                                <ComboBoxItem Content="Always reuse without asking"       Tag="Always"/>
                                <ComboBoxItem Content="Never reuse — always rescan"       Tag="Never"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- Substring-search index -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Substring-search index" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Fast substring search on large logs needs a full-text index that can take a while to build. Choose when it's built (SQLite-backed searches only)."/>
                            <ComboBox x:Name="IndexingModeCombo" Width="360"
                                      SelectionChanged="IndexingModeCombo_SelectionChanged"
                                      AutomationProperties.Name="Search index mode">
                                <ComboBoxItem Content="Background — build after the viewer opens (default)" Tag="Background"/>
                                <ComboBoxItem Content="Lazy — build on first search / focus"             Tag="Lazy"/>
                                <ComboBoxItem Content="Eager — build during load (slower open, instant search)" Tag="Eager"/>
                            </ComboBox>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Lazy opens fastest and skips the index entirely if you never search. Until the index is built, substring search uses a slower scan. Takes effect on the next search."/>
                            <CheckBox x:Name="IndexTimestampsCheck" Margin="0,4,0,0"
                                      Content="Include timestamps in substring search"
                                      Checked="IndexTimestampsCheck_Changed" Unchecked="IndexTimestampsCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Off by default: timestamps are very uniform, so indexing them makes the index build markedly slower for little benefit — the time-range filters cover time either way. Turn on only if you type date/time text into the search box. Changing this rebuilds the index on the next search."/>
                        </StackPanel>
                    </Border>

                    <!-- Loading performance -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Loading performance" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ParallelIngestCheck" Margin="0,4,0,0"
                                      Content="Parallel ingest for large logs (faster first open)"
                                      Checked="ParallelIngestCheck_Changed" Unchecked="ParallelIngestCheck_Changed"/>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="On by default. Large logs load by inserting across several writer threads while one thread decodes, then merging — about 2× faster first open on a multi-million-event .etl. Turn off to use the slower single-writer load (the fail-safe), which also lets rows appear in the viewer live as they load. Takes effect on the next search."/>
                        </StackPanel>
                    </Border>

                    <!-- Search box submit -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search box" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When the search box runs a search. Searching a huge log on every keystroke can make typing lag, so you can require pressing Enter instead."/>
                            <ComboBox x:Name="SearchSubmitModeCombo" Width="360"
                                      SelectionChanged="SearchSubmitModeCombo_SelectionChanged"
                                      AutomationProperties.Name="Search submit mode">
                                <ComboBoxItem Content="Auto — live, but Enter-to-search on large/slow logs (default)" Tag="Auto"/>
                                <ComboBoxItem Content="Live — search as you type"  Tag="Live"/>
                                <ComboBoxItem Content="On Enter — only search when you press Enter" Tag="OnEnter"/>
                            </ComboBox>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Auto keeps live search on small logs and switches to Enter-to-search once a search takes about a second (or the log is large), then back to live once searches are fast again."/>
                        </StackPanel>
                    </Border>

                    <!-- Search progress -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search progress" FontWeight="SemiBold"/>
                            <CheckBox x:Name="ShowStepHistoryCheck" Content="Show completed steps above the current step"
                                      Checked="ShowStepHistoryCheck_Changed" Unchecked="ShowStepHistoryCheck_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- Search storage backend -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Search storage" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Where search results are kept while you view them. Auto picks based on result size."/>
                            <ComboBox x:Name="StorageCombo" Width="280"
                                      SelectionChanged="StorageCombo_SelectionChanged"
                                      AutomationProperties.Name="Search storage backend">
                                <ComboBoxItem Content="Auto (recommended)"     Tag="Auto"/>
                                <ComboBoxItem Content="In-memory (fastest, &lt; 100k rows)"  Tag="InMemory"/>
                                <ComboBoxItem Content="Hybrid (RAM + SQLite spillover)"      Tag="Hybrid"/>
                                <ComboBoxItem Content="SQLite only (smallest memory)"        Tag="SqlLite"/>
                            </ComboBox>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" TextWrapping="Wrap"
                                       Text="Auto picks: in-memory under 10k rows, hybrid up to 1M, SQLite above. Takes effect on the next search."/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============================ COLUMNS ============================ -->
                <StackPanel x:Name="PanelColumns" Spacing="16" Visibility="Collapsed">

                    <!-- Default columns -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <Grid>
                                <TextBlock Text="Default columns" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="Reset to defaults" Click="ResetColumnDefaults_Click"
                                        HorizontalAlignment="Right" FontSize="12"/>
                            </Grid>
                            <TextBlock Text="Which columns are shown when you open the result viewer. The viewer's Columns ▾ popover can still toggle any column for the current session."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <nrv:WrapPanelLite x:Name="ColumnDefaultsPanel" HorizontalSpacing="16" VerticalSpacing="8"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============================ DECODING ============================ -->
                <StackPanel x:Name="PanelDecoding" Spacing="16" Visibility="Collapsed">

                    <!-- Event payload format (ETW TraceLogging etc.) -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Event payload format" FontWeight="SemiBold"/>
                            <TextBlock Text="How a structured event's fields (e.g. ETW TraceLogging) are shown in the Message column. Applies instantly — no re-scan."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                            <ComboBox x:Name="PayloadFormatCombo" Width="260"
                                      SelectionChanged="PayloadFormatCombo_SelectionChanged"
                                      AutomationProperties.Name="Event payload format">
                                <ComboBoxItem Content="key=&quot;value&quot; (PerfView)" Tag="KeyValueQuoted"/>
                                <ComboBoxItem Content="key=value (logfmt)"         Tag="KeyValue"/>
                                <ComboBoxItem Content="JSON"                        Tag="Json"/>
                                <ComboBoxItem Content="key: value | (legacy)"      Tag="Pipe"/>
                                <ComboBoxItem Content="Custom template…"            Tag="Custom"/>
                            </ComboBox>
                            <StackPanel x:Name="PayloadCustomPanel" Spacing="4" Visibility="Collapsed">
                                <TextBlock Text="Custom template — tokens {name} and {value}, applied per field (include your own separator):"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>
                                <TextBox x:Name="PayloadCustomTemplateBox" Width="360" FontFamily="Consolas"
                                         LostFocus="PayloadCustomTemplate_LostFocus"
                                         AutomationProperties.Name="Custom payload template"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- WPP / tracefmt symbols -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="WPP symbols (tracefmt TMF path)" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="WPP-traced .etl files need TMF files (extracted from the binary's PDB via tracepdb) to decode — otherwise events show as 'Unknown'. Point this at the folder containing your .tmf files; FindNeedle passes it to tracefmt. Separate multiple folders with ';'."/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="TmfPathBox" Width="460" PlaceholderText="e.g. C:\symbols\tmf"
                                         LostFocus="TmfPathBox_LostFocus"
                                         AutomationProperties.Name="TMF search path"/>
                                <Button Content="Browse…" Click="BrowseTmfPath_Click"/>
                            </StackPanel>

                            <TextBlock Text="…or build TMFs from symbols" FontWeight="SemiBold" Margin="0,8,0,0"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Point at a folder of PDBs and/or the binaries that produced the trace, plus a symbol path (PDB folders or a symbol server, srv*cache*https://…). 'Build TMFs' runs tracepdb to extract TMFs into a managed cache that's used automatically."/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBox x:Name="SymbolSourceBox" Width="460" PlaceholderText="PDBs / binaries folder"
                                         LostFocus="SymbolSourceBox_LostFocus" AutomationProperties.Name="PDB or binary source folder"/>
                                <Button Content="Browse…" Click="BrowseSymbolSource_Click"/>
                            </StackPanel>
                            <TextBox x:Name="SymbolPathBox" Width="560" HorizontalAlignment="Left"
                                     PlaceholderText="Symbol path, e.g. srv*C:\symcache*https://msdl.microsoft.com/download/symbols"
                                     LostFocus="SymbolPathBox_LostFocus" AutomationProperties.Name="Symbol path"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Defaults to the Microsoft public symbol server, so WPP traces from Microsoft binaries resolve automatically — the first decode may download PDBs (slower). Clear this box to disable, or set your own PDB folders / symbol server."/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="BuildTmfsButton" Content="Build TMFs from symbols" Click="BuildTmfs_Click"/>
                                <TextBlock x:Name="BuildTmfsStatus" VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============================ INTEGRATIONS ============================ -->
                <StackPanel x:Name="PanelIntegrations" Spacing="16" Visibility="Collapsed">

                    <!-- MCP server -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="MCP server (experimental)" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Host a local Model Context Protocol endpoint so an AI agent can read and drive the live result viewer (search, filter, page, tag, export). Bound to 127.0.0.1 only — it exposes your loaded logs and lets an agent act in the app, so it is off by default."/>
                            <CheckBox x:Name="McpEnabledCheck" Content="Enable the in-app MCP server"
                                      Checked="McpEnabledCheck_Changed" Unchecked="McpEnabledCheck_Changed"/>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="Port" VerticalAlignment="Center"/>
                                <TextBox x:Name="McpPortBox" Width="100" InputScope="Number"
                                         LostFocus="McpPortBox_LostFocus"
                                         AutomationProperties.Name="MCP server port"/>
                            </StackPanel>
                            <TextBlock x:Name="McpStatusText" FontFamily="Consolas" FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" IsTextSelectionEnabled="True"/>
                        </StackPanel>
                    </Border>

                    <!-- File associations -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="File associations" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When installed from the Microsoft Store, FindNeedle can open these file types straight from Explorer's right-click &quot;Open with&quot; menu. Windows lets you choose which app is the default for each type."/>
                            <TextBlock Text="Supported file types" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="FileAssocList" FontFamily="Consolas" FontSize="13"
                                       IsTextSelectionEnabled="True"/>

                            <CheckBox x:Name="OpenWithCheck" Margin="0,4,0,0"
                                      Content="Show FindNeedle in Explorer's &quot;Open with&quot; menu"
                                      Checked="OpenWithCheck_Changed" Unchecked="OpenWithCheck_Changed"/>
                            <CheckBox x:Name="ContextMenuCheck"
                                      Content="Add a right-click &quot;Open in FindNeedle&quot; entry"
                                      Checked="ContextMenuCheck_Changed" Unchecked="ContextMenuCheck_Changed"/>
                            <TextBlock x:Name="FileIntegrationNote" FontSize="11" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Applies to this installed copy, for your user. On Windows 11 the right-click entry appears under &quot;Show more options&quot;."/>

                            <Button Content="Manage defaults in Windows…" Click="ManageDefaultApps_Click"
                                    FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ============================ LOGS ============================ -->
                <StackPanel x:Name="PanelLogs" Spacing="16" Visibility="Collapsed">

                    <!-- Diagnostics: bundle logs for the developer -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Diagnostics" FontWeight="SemiBold"/>
                            <TextBlock TextWrapping="Wrap" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Bundle the app logs, settings, plugin config, and system info into a single .zip you can attach to a bug report. No log file contents are uploaded anywhere — you choose where to save it."/>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button x:Name="SendLogsButton" Content="Send app logs to dev…" Click="SendLogs_Click"/>
                                <TextBlock x:Name="SendLogsStatus" VerticalAlignment="Center" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Settings file path -->
                    <Border Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Settings file" FontWeight="SemiBold"/>
                            <TextBlock Text="Where your per-user viewer settings are stored on disk."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                            <TextBlock x:Name="SettingsPathText" FontFamily="Consolas" FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       IsTextSelectionEnabled="True" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </NavigationView>
</Page>
