{
  "title": "Crash Detection with UML Sequence",
  "description": "UML sequence diagrams for .NET application crash scenarios showing the flow between Application, Runtime, and OS layers.",
  "participants": [
    { "id": "App", "displayName": "Application", "type": "participant" },
    { "id": "Runtime", "displayName": ".NET Runtime", "type": "participant" },
    { "id": "OS", "displayName": "Operating System", "type": "actor" }
  ],
  "rules": [
    {
      "name": "DotNetApplicationCrash",
      "match": "A .NET application failed",
      "enabled": true,
      "action": {
        "type": "message",
        "from": "App",
        "to": "Runtime",
        "text": "Exception thrown (pid={extract:ProcessId=(\\d+)})"
      }
    },
    {
      "name": "ActivateRuntimeOnCrash",
      "match": "A .NET application failed",
      "enabled": true,
      "action": {
        "type": "activate",
        "from": "Runtime",
        "text": ""
      }
    },
    {
      "name": "RuntimeReportsNativeFault",
      "match": "faulting application",
      "enabled": true,
      "action": {
        "type": "message",
        "from": "Runtime",
        "to": "OS",
        "text": "Native fault: {extract:faulting module:\\s*(\\S+)}"
      }
    },
    {
      "name": "AccessViolationNote",
      "match": "access violation",
      "unmatch": "allowed",
      "enabled": true,
      "action": {
        "type": "note",
        "from": "Runtime",
        "text": "Access violation address: {afterMatch:untilSpace}",
        "notePosition": "right"
      }
    },
    {
      "name": "OutOfMemoryEvent",
      "match": "OutOfMemoryException",
      "enabled": true,
      "action": {
        "type": "message",
        "from": "Runtime",
        "to": "App",
        "text": "OutOfMemoryException occurred"
      }
    },
    {
      "name": "StackOverflowEvent",
      "match": "StackOverflowException",
      "enabled": true,
      "action": {
        "type": "message",
        "from": "Runtime",
        "to": "App",
        "text": "StackOverflowException"
      }
    },
    {
      "name": "DeactivateRuntimeOnCompletion",
      "match": "OutOfMemoryException|StackOverflowException|faulting application",
      "useRegex": true,
      "enabled": true,
      "action": {
        "type": "deactivate",
        "from": "Runtime",
        "text": ""
      }
    }
  ]
}
